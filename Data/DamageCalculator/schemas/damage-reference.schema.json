{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/TWHome-Git/TWHomeDB/main/schemas/damage-reference.schema.json",
  "title": "TWHome Damage Reference Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "버전",
    "에타레벨정보",
    "각성정보",
    "몬스터정보"
  ],
  "properties": {
    "버전": {
      "type": "string"
    },
    "에타레벨정보": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/etaLevel"
      }
    },
    "각성정보": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/awakening"
      }
    },
    "몬스터정보": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/monster"
      }
    }
  },
  "$defs": {
    "etaLevel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "LV",
        "증댐",
        "대미지상한"
      ],
      "properties": {
        "LV": {
          "type": "integer",
          "minimum": 0
        },
        "증댐": {
          "type": "number",
          "minimum": 0
        },
        "대미지상한": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "awakening": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "각성",
        "대미지증가배율"
      ],
      "properties": {
        "각성": {
          "type": "integer",
          "minimum": 0
        },
        "대미지증가배율": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "monster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "이름",
        "스탯방어력",
        "고정방어력",
        "고정피해감소",
        "피해감소율",
        "속성수치",
        "HP솔로"
      ],
      "properties": {
        "이름": {
          "type": "string"
        },
        "스탯방어력": {
          "type": "number",
          "minimum": 0
        },
        "고정방어력": {
          "type": "number",
          "minimum": 0
        },
        "고정피해감소": {
          "type": "number",
          "minimum": 0
        },
        "피해감소율": {
          "type": "number",
          "minimum": 0
        },
        "속성수치": {
          "type": "number",
          "minimum": 0
        },
        "HP솔로": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
