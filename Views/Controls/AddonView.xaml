<UserControl x:Class="TWChatOverlay.Views.AddonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource OverlayScrollViewerStyle}">
        <Border Background="#F51E1E1E" Padding="15">
            <TabControl Style="{StaticResource SettingsTabControlStyle}" Margin="0,1,0,0">
                <TabItem Header="키워드 알림" Style="{StaticResource SettingsTabItemStyle}" Margin="0,0,0,0">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SettingsBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="키워드 알림 설정" Style="{StaticResource SectionHeaderStyle}"/>

                                <StackPanel Margin="0,0,0,12">
                                    <CheckBox Content="색상 강조"
                                              IsChecked="{Binding UseAlertColor}"
                                              Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                    <CheckBox Content="알림음 재생"
                                              IsChecked="{Binding UseAlertSound}"
                                              Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                    <StackPanel Margin="6,6,0,0">
                                        <TextBlock Text="{Binding HighlightAlertVolumePercent, StringFormat=키워드 알림 볼륨: {0:F0}%}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   Margin="0,0,0,6"/>
                                        <Slider Minimum="0"
                                                Maximum="100"
                                                TickFrequency="10"
                                                IsSnapToTickEnabled="True"
                                                Tag="Highlight.wav"
                                                ValueChanged="PreviewSoundSlider_ValueChanged"
                                                Value="{Binding HighlightAlertVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="알림 키워드 입력 (@단어1 @단어2 형식)"
                                           Style="{StaticResource InfoTextStyle}"/>
                                <TextBox x:Name="KeywordBox"
                                         Text="{Binding KeywordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="80"/>
                                <TextBlock Text="* 입력 즉시 자동으로 적용됩니다."
                                           Style="{StaticResource HintTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="경험치 추적" Style="{StaticResource SettingsTabItemStyle}" Margin="4,0,-4,0">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SettingsBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="경험치 추적" Style="{StaticResource SectionHeaderStyle}"/>

                                <CheckBox Content="경험치 추적기능 활성화"
                                          IsChecked="{Binding ShowExpTracker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>

                                <TextBlock Text="* 활성화하면 상단에 실시간 획득량이 표시됩니다."
                                           Foreground="#888"
                                           FontSize="11"
                                           Margin="0,6,0,15"/>

                                <Border Height="1"
                                        Background="#333"
                                        Margin="0,4,0,14"/>

                                <CheckBox Content="경험치 누적 알림"
                                          IsChecked="{Binding EnableExperienceLimitAlert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>

                                <CheckBox Content="경험치 누적 창 표시"
                                          IsChecked="{Binding ShowExperienceLimitAlertWindow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>

                                <TextBlock Text="* 창 표시를 켜면 알림 위치를 드래그로 조정할 수 있습니다."
                                           Foreground="#888"
                                           FontSize="11"
                                           Margin="0,6,0,15"/>

                                <StackPanel Margin="0,0,0,0">
                                    <CheckBox IsChecked="{Binding IsExpAlarmEnabled}"
                                              Content="저효율 알림 활성화"
                                              Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                    <StackPanel Margin="6,6,0,8">
                                        <TextBlock Text="{Binding ExpBuffAlertVolumePercent, StringFormat=저효율 알림 볼륨: {0:F0}%}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   Margin="0,0,0,6"/>
                                        <Slider Minimum="0"
                                                Maximum="100"
                                                TickFrequency="10"
                                                IsSnapToTickEnabled="True"
                                                Tag="EXPBuffCheck.wav"
                                                ValueChanged="PreviewSoundSlider_ValueChanged"
                                                Value="{Binding ExpBuffAlertVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="기준치"
                                                   Margin="0,0,5,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"
                                                   FontSize="13"/>
                                        <TextBox Text="{Binding ExpAlarmThresholdMan, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60"
                                                 VerticalAlignment="Center"
                                                 HorizontalContentAlignment="Center"
                                                 Margin="0,0,5,0"
                                                 Style="{StaticResource InputTextBoxStyle}"/>
                                        <TextBlock Text="만 EXP 미만 시"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="마법진 경고" Style="{StaticResource SettingsTabItemStyle}" Margin="4,0,-4,0">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SettingsBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="마법진 경고" Style="{StaticResource SectionHeaderStyle}"/>

                                <CheckBox Content="마법진 경고"
                                          IsChecked="{Binding UseMagicCircleAlert}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                <StackPanel Margin="6,6,0,8">
                                    <TextBlock Text="{Binding MagicCircleAlertVolumePercent, StringFormat=마법진 경고 볼륨: {0:F0}%}"
                                               Foreground="White"
                                               FontSize="12"
                                               Margin="0,0,0,6"/>
                                    <Slider Minimum="0"
                                            Maximum="100"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            Tag="MagicCircle.wav"
                                            ValueChanged="PreviewSoundSlider_ValueChanged"
                                            Value="{Binding MagicCircleAlertVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="에토스 방향 알림" Style="{StaticResource SettingsTabItemStyle}" Margin="4,0,-4,0">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SettingsBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="에토스 방향 알림" Style="{StaticResource SectionHeaderStyle}"/>

                                <CheckBox Content="에토스 방향 알림"
                                          IsChecked="{Binding ShowEtosDirectionAlert}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                <CheckBox Content="에토스 방향 창 표시"
                                          IsChecked="{Binding ShowEtosHelperWindow}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="아이템 획득 알림" Style="{StaticResource SettingsTabItemStyle}" Margin="4,0,-4,0">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SettingsBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="아이템 획득 알림" Style="{StaticResource SectionHeaderStyle}"/>

                                <CheckBox Content="아이템 획득 알림"
                                          IsChecked="{Binding ShowItemDropAlert}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                <StackPanel Margin="6,6,0,8">
                                    <TextBlock Text="{Binding ItemDropAlertVolumePercent, StringFormat=아이템 획득 볼륨: {0:F0}%}"
                                               Foreground="White"
                                               FontSize="12"
                                               Margin="0,0,0,6"/>
                                    <Slider Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Tag="drop_low.mp3"
                                            ValueChanged="PreviewSoundSlider_ValueChanged"
                                            Value="{Binding ItemDropAlertVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <CheckBox Content="아이템 획득 창 표시"
                                          IsChecked="{Binding ShowItemDropHelperWindow}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>

                                <TextBlock Text="* 창 표시를 켜두면 드래그로 알림 위치를 옮길 수 있습니다."
                                           Style="{StaticResource HintTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="버프 추적" Style="{StaticResource SettingsTabItemStyle}" Margin="4,0,-4,0">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SettingsBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="버프 추적" Style="{StaticResource SectionHeaderStyle}"/>

                                <CheckBox Content="버프 추적 알림"
                                          IsChecked="{Binding EnableBuffTrackerAlert}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>

                                <CheckBox Content="버프 추적 창 표시"
                                          IsChecked="{Binding ShowBuffTrackerWindow}"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>

                                <TextBlock Text="* 버프 추적 알림은 실제 버프 시간 추적을 켜고 끕니다."
                                           Style="{StaticResource HintTextStyle}"/>
                                <TextBlock Text="* 창 표시는 위치를 옮기기 위한 용도로만 사용됩니다."
                                           Style="{StaticResource HintTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="필드 보스 알림" Style="{StaticResource SettingsTabItemStyle}" Margin="4,0,-4,0">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SettingsBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="필드 보스 알림" Style="{StaticResource SectionHeaderStyle}"/>
                                <Button x:Name="DebugRefreshBossTimerButton"
                                        Content="BossTimer 새로고침"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,12"
                                        Padding="12,6"
                                        Visibility="Collapsed"
                                        Click="DebugRefreshBossTimerButton_Click"/>
                                <ItemsControl ItemsSource="{Binding BossAlarmCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,14,14">
                                                <Border Padding="14"
                                                        Background="#FF262626"
                                                        BorderBrush="#404040"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="White"
                                                                   FontSize="17"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding ScheduleText}"
                                                                   Foreground="#9FB0C0"
                                                                   FontSize="11"
                                                                   Margin="0,4,0,12"
                                                                   TextWrapping="Wrap"/>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="3분 전"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"/>
                                                            <CheckBox Grid.Column="1"
                                                                      IsChecked="{Binding Alert3MinutesBefore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="1분 전"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"/>
                                                            <CheckBox Grid.Column="1"
                                                                      IsChecked="{Binding Alert1MinuteBefore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                                        </Grid>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="등장 시"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"/>
                                                            <CheckBox Grid.Column="1"
                                                                      IsChecked="{Binding AlertAtSpawn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Height="1"
                                        Background="#333"
                                        Margin="0,8,0,8"/>
                                <StackPanel Margin="6,4,0,0">
                                    <TextBlock Text="{Binding BossAlertVolumePercent, StringFormat=필드 보스 알림 볼륨: {0:F0}%}"
                                               Foreground="White"
                                               FontSize="12"
                                               Margin="0,0,0,6"/>
                                    <Slider Minimum="0"
                                            Maximum="100"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            Tag="Arkan.wav"
                                            ValueChanged="PreviewSoundSlider_ValueChanged"
                                            Value="{Binding BossAlertVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>
    </ScrollViewer>
</UserControl>
