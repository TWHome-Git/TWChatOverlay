<UserControl x:Class="TWChatOverlay.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Border x:Name="RootBorder" Background="{StaticResource PrimaryBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

                <TabControl x:Name="SettingsTabControl" Grid.Row="0" Style="{StaticResource SettingsTabControlStyle}" SelectedIndex="0" Margin="0,1,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <TabItem Header="채팅창 설정" Margin="0,0,0,0">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OnlyChatMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid Margin="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource SettingsBorderStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="채팅 필터 및 색상" Style="{StaticResource SubsectionHeaderStyle}"/>
                                    <UniformGrid Columns="2" Margin="5,0,0,0">
                                        <Grid Margin="0,5,15,5">
                                            <CheckBox Content="일반" IsChecked="{Binding ShowNormal}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <Button Width="35" Height="18" HorizontalAlignment="Right" Background="{Binding NormalColor}" Command="{Binding ColorPickCommand}" CommandParameter="Normal" Style="{StaticResource ColorPickerButtonStyle}"/>
                                        </Grid>
                                        <Grid Margin="15,5,0,5">
                                            <CheckBox Content="팀" IsChecked="{Binding ShowTeam}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <Button Width="35" Height="18" HorizontalAlignment="Right" Background="{Binding TeamColor}" Command="{Binding ColorPickCommand}" CommandParameter="Team" Style="{StaticResource ColorPickerButtonStyle}"/>
                                        </Grid>
                                        <Grid Margin="0,5,15,5">
                                            <CheckBox Content="클럽" IsChecked="{Binding ShowClub}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <Button Width="35" Height="18" HorizontalAlignment="Right" Background="{Binding ClubColor}" Command="{Binding ColorPickCommand}" CommandParameter="Club" Style="{StaticResource ColorPickerButtonStyle}"/>
                                        </Grid>
                                        <Grid Margin="15,5,0,5">
                                            <CheckBox Content="외치기" IsChecked="{Binding ShowShout}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <Button Width="35" Height="18" HorizontalAlignment="Right" Background="{Binding ShoutColor}" Command="{Binding ColorPickCommand}" CommandParameter="Shout" Style="{StaticResource ColorPickerButtonStyle}"/>
                                        </Grid>
                                        <Grid Margin="0,5,15,5">
                                            <CheckBox Content="시스템" IsChecked="{Binding ShowSystem}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <Button Width="35" Height="18" HorizontalAlignment="Right" Background="{Binding SystemColor}" Command="{Binding ColorPickCommand}" CommandParameter="System" Style="{StaticResource ColorPickerButtonStyle}"/>
                                        </Grid>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsBorderStyle}" Margin="0,12,0,13" Grid.Row="1">
                                <StackPanel>
                                    <TextBlock Text="텍스트 설정" Style="{StaticResource SubsectionHeaderStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="폰트 종류" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <UniformGrid Columns="3">
                                                <RadioButton x:Name="NanumFontOption" Content="나눔고딕" Tag="나눔고딕" GroupName="FontFamilyOptions" Height="30" Margin="0,0,4,0" Checked="FontOption_Checked" Style="{StaticResource FontOptionButtonStyle}"/>
                                                <RadioButton x:Name="GulimFontOption" Content="굴림" Tag="굴림" GroupName="FontFamilyOptions" Height="30" Margin="0,0,4,0" Checked="FontOption_Checked" Style="{StaticResource FontOptionButtonStyle}"/>
                                                <RadioButton x:Name="CustomFontOption" Content="사용자 설정" Tag="사용자 설정" GroupName="FontFamilyOptions" Height="30" Checked="FontOption_Checked" Style="{StaticResource FontOptionButtonStyle}"/>
                                            </UniformGrid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="크기" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <DockPanel>
                                                <TextBlock Text="{Binding FontSize, StringFormat={}{0:F0}}" Foreground="White" Width="25" DockPanel.Dock="Right" TextAlignment="Right" VerticalAlignment="Center"/>
                                                <Slider Minimum="10" Maximum="40" Value="{Binding FontSize}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Grid>
                                    <Border Height="1" Background="#2E3640" Margin="0,12,0,12"/>
                                    <StackPanel>
                                        <TextBlock Text="외치기 설정" Style="{StaticResource SubsectionHeaderStyle}" Margin="0,0,0,8"/>
                                        <CheckBox Content="외치기 팝업"
                                                  IsChecked="{Binding ShowShoutToastPopup}"
                                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                        <TextBlock Text="외치기 로그가 들어오면 토스트 팝업을 표시합니다."
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="26,0,0,8"/>
                                        <CheckBox Content="외치기 닉네임 자동복사"
                                                  IsChecked="{Binding AutoCopyShoutNickname}"
                                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                        <TextBlock Text="외치기 로그 끝의 [닉네임]을 자동으로 클립보드에 복사합니다."
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="26,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="메시지 유지 시간(초)" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding ShoutToastDurationSeconds, UpdateSourceTrigger=LostFocus}"
                                                         Height="28"
                                                         Background="#333"
                                                         Foreground="White"
                                                         BorderBrush="#555"
                                                         VerticalContentAlignment="Center"
                                                         TextAlignment="Center"
                                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                                         KeyDown="OffsetInput_KeyDown"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="외치기 토스트 메시지 크기" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding ShoutToastFontSize, StringFormat={}{0:F0}}" Foreground="White" Width="25" DockPanel.Dock="Right" TextAlignment="Right" VerticalAlignment="Center"/>
                                                    <Slider Minimum="10" Maximum="40" Value="{Binding ShoutToastFontSize}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="프로그램 설정" x:Name="ProgramTab" Margin="0,0,0,0">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OnlyChatMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid Margin="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Margin="0,0,0,12" Style="{StaticResource SettingsBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="위치 설정" Style="{StaticResource SubsectionHeaderStyle}"/>
                                        <StackPanel Margin="0,0,0,15">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton Content="1" IsChecked="{Binding SelectedPresetNumber, Converter={StaticResource EqualValueToBoolConverter}, ConverterParameter=1}" Tag="1" Style="{StaticResource PresetRadioButtonStyle}"/>
                                                <RadioButton Content="2" IsChecked="{Binding SelectedPresetNumber, Converter={StaticResource EqualValueToBoolConverter}, ConverterParameter=2}" Tag="2" Style="{StaticResource PresetRadioButtonStyle}"/>
                                                <RadioButton Content="3" IsChecked="{Binding SelectedPresetNumber, Converter={StaticResource EqualValueToBoolConverter}, ConverterParameter=3}" Tag="3" Style="{StaticResource PresetRadioButtonStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <UniformGrid Columns="2" Margin="0,0,0,12">
                                            <Button Content="저장" Height="32" Margin="0,0,5,0" Command="{Binding SaveOrLoadPresetCommand}" CommandParameter="Save" Background="#30FFFFFF" Foreground="White" FontSize="12" Cursor="Hand"/>
                                            <Button Content="불러오기" Height="32" Margin="5,0,0,0" Command="{Binding SaveOrLoadPresetCommand}" CommandParameter="Load" Background="#307FFF8F" Foreground="White" FontSize="12" Cursor="Hand"/>
                                        </UniformGrid>
                                        <CheckBox Content="항상 보이기" IsChecked="{Binding AlwaysVisible}" Foreground="White" Margin="0,0,0,10"/>
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,10,0">
                                                <TextBlock Text="X 좌표 (좌우)" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding LineMarginLeft, UpdateSourceTrigger=LostFocus}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewTextInput="NumberOnly_PreviewTextInput" KeyDown="OffsetInput_KeyDown"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock Text="Y 좌표 (상하)" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding LineMargin, UpdateSourceTrigger=LostFocus}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewTextInput="NumberOnly_PreviewTextInput" KeyDown="OffsetInput_KeyDown"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,0">
                                    <Border Style="{StaticResource SettingsBorderStyle}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="로그 경로 설정" Style="{StaticResource SubsectionHeaderStyle}"/>
                                            <TextBlock Text="채팅 로그 폴더 경로" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ChatLogFolderPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" Padding="5,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="DebugOptionsBorder" Style="{StaticResource SettingsBorderStyle}" Margin="0,0,0,12" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="로그 활성화" Style="{StaticResource SubsectionHeaderStyle}"/>
                                            <CheckBox Content="Debug.log 활성화"
                                                      IsChecked="{Binding EnableDebugLogging}"
                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>
                                            <TextBlock Text="디버그 로그를 활성화하면 Debug.log 파일에 로그가 기록됩니다."
                                                       Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                    </Border>

                                    <UniformGrid Columns="2" Margin="0,8,0,0">
                                        <Button Content="설정 초기화" Height="32" Margin="0,0,5,0" Command="{Binding InitSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" FontSize="12"/>
                                        <Button Content="프로그램 종료" Height="32" Margin="5,0,0,0" Command="{Binding ExitAppCommand}" Style="{StaticResource DangerButtonStyle}" FontSize="12"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="단축키 설정" x:Name="HotkeyTab" Margin="0,0,0,0">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OnlyChatMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid Margin="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource SettingsBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="단축키 설정" Style="{StaticResource SubsectionHeaderStyle}"/>
                                    <UniformGrid Columns="2">
                                        <!-- 1: 채팅창 ON/OFF -->
                                        <StackPanel Margin="0,0,5,10">
                                            <TextBlock Text="채팅창 ON/OFF" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ToggleOverlayHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 2: ETA 랭킹 ON/OFF -->
                                        <StackPanel Margin="5,0,0,10">
                                            <TextBlock Text="ETA 랭킹 ON/OFF" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ToggleEtaRankingHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 3: 계산기 ON/OFF -->
                                        <StackPanel Margin="0,0,5,10">
                                            <TextBlock Text="계산기 ON/OFF" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ToggleCoefficientHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 4: 장비목록 ON/OFF -->
                                        <StackPanel Margin="5,0,0,10">
                                            <TextBlock Text="장비목록 ON/OFF" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ToggleEquipmentDbHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 5: 일일/주간 콘텐츠 ON/OFF -->
                                        <StackPanel Margin="0,0,5,10">
                                            <TextBlock Foreground="#888" FontSize="12" Margin="0,0,0,5">일일/주간 콘텐츠 ON/OFF</TextBlock>
                                            <TextBox Text="{Binding ToggleDailyWeeklyContentHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 6: 인크립트 ON/OFF -->
                                        <StackPanel Margin="5,0,0,10">
                                            <TextBlock Foreground="#888" FontSize="12" Margin="0,0,0,5">인크립트 ON/OFF</TextBlock>
                                            <TextBox Text="{Binding ToggleEncryptHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 7: 추가기능 ON/OFF -->
                                        <StackPanel Margin="0,0,5,10">
                                            <TextBlock Foreground="#888" FontSize="12" Margin="0,0,0,5">추가기능 ON/OFF</TextBlock>
                                            <TextBox Text="{Binding ToggleAddonHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 8: 설정창 ON/OFF -->
                                        <StackPanel Margin="5,0,0,10">
                                            <TextBlock Foreground="#888" FontSize="12" Margin="0,0,0,5">설정창 ON/OFF</TextBlock>
                                            <TextBox Text="{Binding ToggleSettingsHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 9: 항상 보이기 ON/OFF -->
                                        <StackPanel Margin="0,0,5,10">
                                            <TextBlock Text="항상 보이기 ON/OFF" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ToggleAlwaysVisibleHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>

                                        <!-- 10: 프로그램 종료 -->
                                        <StackPanel Margin="5,0,0,10">
                                            <TextBlock Text="프로그램 종료" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ExitHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" TextAlignment="Center" PreviewKeyDown="HotKeyInput_PreviewKeyDown" PreviewMouseLeftButtonDown="HotKeyTextBox_PreviewMouseLeftButtonDown" IsReadOnly="True" Tag="HotKey"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <UniformGrid Columns="2" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
        </Grid>
    </Border>
</UserControl>
