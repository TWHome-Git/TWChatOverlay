<UserControl x:Class="TWChatOverlay.Views.Addons.EquipmentDbView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#161B22" CornerRadius="8" Margin="0,0,15,0" BorderBrush="#30363D" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="5">
                    <TextBlock Text="장비 DB" Foreground="#58A6FF" FontSize="11" FontWeight="Bold" Margin="10,10,10,15"/>
                    <Button Content="전체보기" Tag="전체" Click="CategoryButton_Click" Style="{StaticResource CategoryButtonStyle}"/>
                    <Separator Background="#30363D" Margin="5,10"/>
                    <ItemsControl x:Name="CategoryMenuControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Foreground="White" BorderThickness="0" Margin="0,2">
                                    <Expander.Header>
                                        <Border Tag="{Binding MajorName}"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="10,8"
                                                HorizontalAlignment="Stretch"
                                                PreviewMouseLeftButtonDown="MajorCategory_Header_Click">
                                            <TextBlock Text="{Binding MajorName}" FontSize="13" VerticalAlignment="Center"/>
                                        </Border>
                                    </Expander.Header>

                                    <ItemsControl ItemsSource="{Binding SubCategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding}"
                                                        Tag="{Binding}"
                                                        Click="CategoryButton_Click"
                                                        Style="{StaticResource SubCategoryButtonStyle}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1" Margin="0,0,0,10" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Foreground="#8B949E" Margin="0,0,10,0" FontSize="14"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged" CaretBrush="Cyan"/>
                    <TextBlock Grid.Column="1" Text="아이템 이름으로 검색..." Foreground="#484F58" IsHitTestVisible="False" VerticalAlignment="Center" FontSize="13" Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" x:Name="EquipmentGrid" AutoGenerateColumns="False" Background="Transparent" RowBackground="#161B22" AlternatingRowBackground="#1C2128" BorderThickness="0" Foreground="White" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#30363D" HeadersVisibility="Column" CanUserAddRows="False" RowHeight="75" VerticalContentAlignment="Center" MouseDoubleClick="EquipmentGrid_MouseDoubleClick">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0D1117"/>
                        <Setter Property="Foreground" Value="#8B949E"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="장비 정보" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Grid Width="42" Height="42" Margin="5">
                                        <Border Background="#050505"
                                                BorderBrush="#AA2B2B"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Line X1="6" Y1="6" X2="36" Y2="36" Stroke="#FF3B3B" StrokeThickness="2"/>
                                                <Line X1="36" Y1="6" X2="6" Y2="36" Stroke="#FF3B3B" StrokeThickness="2"/>
                                            </Grid>
                                        </Border>
                                        <Image Source="{Binding ImagePath, TargetNullValue={x:Null}}"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               SnapsToDevicePixels="True"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                    <StackPanel VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="13"/>
                                        <TextBlock Text="{Binding SubCategory}" FontSize="10" Foreground="#58A6FF" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="찌르기" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Stab.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4" SnapsToDevicePixels="True"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Stab.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding Stab.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="베기" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Hack.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Hack.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding Hack.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="물리방어" Width="70" Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center" Visibility="{Binding Def.HasValue, Converter={StaticResource VisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Def.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Def.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding Def.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="마법공격" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Int.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Int.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding Int.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="마법방어" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding MR.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding MR.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding MR.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="명중" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Dex.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Dex.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding Dex.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="회피" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Agi.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Agi.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding Agi.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="민첩" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding SmallAgi.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding SmallAgi.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding SmallAgi.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="크리티컬" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Crit.RangeText}" Foreground="White" HorizontalAlignment="Center"/>
                                    <Border Grid.Row="1" Height="1" Background="#30363D" Margin="5,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Crit.LimitText}" Foreground="#F85149" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Visibility="{Binding Crit.Limit, Converter={StaticResource VisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
