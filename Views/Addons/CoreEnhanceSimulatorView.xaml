<UserControl x:Class="TWChatOverlay.Views.Addons.CoreEnhanceSimulatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="#161B22" Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450" MinWidth="390"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#111821"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#0D1625"
                                BorderBrush="#2E3A4A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <StackPanel>
                                <TextBlock Text="스탯 기준" Foreground="#8B949E" FontSize="12"/>
                                <CheckBox x:Name="MainStatToggle"
                                          Margin="0,4,0,0"
                                          Content="주스탯"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                          Foreground="#C9D1D9"
                                          Checked="MainStatToggle_Changed"
                                          Unchecked="MainStatToggle_Changed"/>
                                <TextBlock x:Name="StatModeTextBlock"
                                           Margin="0,4,0,0"
                                           Foreground="#58A6FF"
                                           FontSize="12"
                                           Text="현재 주스탯"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#0D1625"
                                BorderBrush="#2E3A4A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <StackPanel>
                                <TextBlock Text="진화권 사용" Foreground="#8B949E" FontSize="12"/>
                                <CheckBox x:Name="UseTicketToggle"
                                          Margin="0,4,0,0"
                                          Content="진화권 사용"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                          Foreground="#C9D1D9"
                                          Checked="UseTicketToggle_Changed"
                                          Unchecked="UseTicketToggle_Changed"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="TicketOffPanel"
                                Grid.Column="0"
                                Background="#0D1625"
                                BorderBrush="#2E3A4A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <StackPanel>
                                <CheckBox x:Name="HasDustToggle"
                                          Margin="0,2,0,0"
                                          Content="가루 설정"
                                          Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                          Foreground="#C9D1D9"
                                          Checked="HasDustToggle_Changed"
                                          Unchecked="HasDustToggle_Changed"/>
                                <StackPanel x:Name="BoxPricePanel">
                                    <TextBlock Text="상자 가격" Foreground="#8B949E" FontSize="11" Margin="0,6,0,0"/>
                                    <TextBox x:Name="BoxPriceTextBox"
                                             Text="0"
                                             Height="30"
                                             Margin="0,4,0,0"
                                             Style="{StaticResource SimTextBoxStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#0D1625"
                                BorderBrush="#2E3A4A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <StackPanel>
                                <TextBlock Text="구간 선택" Foreground="#8B949E" FontSize="12"/>
                                <TextBlock Text="시작" Foreground="#C9D1D9" Margin="0,6,0,2"/>
                                <ComboBox x:Name="StartStageComboBox" Height="28"/>
                                <TextBlock Text="목표" Foreground="#C9D1D9" Margin="0,6,0,2"/>
                                <ComboBox x:Name="TargetStageComboBox" Height="28"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border x:Name="TicketOnPanel"
                            Grid.Row="4"
                            Background="#0D1625"
                            BorderBrush="#2E3A4A"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="진화권 가격(억)" Foreground="#8B949E" FontSize="12"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="1진화 강화권" Foreground="#C9D1D9" Margin="0,0,0,3"/>
                                    <TextBox x:Name="Ticket1TextBox" Text="0" Height="30" Style="{StaticResource SimTextBoxStyle}" Margin="0,0,0,6"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="2진화 강화권" Foreground="#C9D1D9" Margin="0,0,0,3"/>
                                    <TextBox x:Name="Ticket2TextBox" Text="0" Height="30" Style="{StaticResource SimTextBoxStyle}" Margin="0,0,0,6"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="3진화 강화권" Foreground="#C9D1D9" Margin="0,0,0,3"/>
                                    <TextBox x:Name="Ticket3TextBox" Text="0" Height="30" Style="{StaticResource SimTextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock Text="4진화 강화권" Foreground="#C9D1D9" Margin="0,0,0,3"/>
                                    <TextBox x:Name="Ticket4TextBox" Text="0" Height="30" Style="{StaticResource SimTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="6"
                            Content="기대값 계산"
                            Height="34"
                            Style="{StaticResource SimButtonStyle}"
                            Click="CalculateButton_Click"/>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2"
                Background="#111821"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="ResultGrid"
                          AutoGenerateColumns="False"
                          Background="#0D1625"
                          BorderBrush="#2E3A4A"
                          BorderThickness="1"
                          Foreground="#E6EDF3"
                          FontSize="13"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="30"
                          RowHeaderWidth="0"
                          SnapsToDevicePixels="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          GridLinesVisibility="Horizontal"
                          RowBackground="#0D1625"
                          AlternatingRowBackground="#121D2D"
                          HorizontalGridLinesBrush="#2E3A4A"
                          VerticalGridLinesBrush="#2E3A4A"
                          ColumnHeaderHeight="28">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1A2332"/>
                            <Setter Property="Foreground" Value="#F0F6FC"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#2E3A4A"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8,2"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#243247"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                        <Style x:Key="CellTextLeftStyle" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Left"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                        <Style x:Key="CellTextCenterStyle" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                        <Style x:Key="CellTextRightStyle" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="StageColumn" Header="단계" Binding="{Binding StageLabel}" Width="1.0*" ElementStyle="{StaticResource CellTextLeftStyle}"/>
                        <DataGridTextColumn x:Name="MethodColumn" Header="확률" Binding="{Binding MethodText}" Width="0.8*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn x:Name="AttemptsColumn" Header="시도" Binding="{Binding ExpectedAttemptsText}" Width="0.7*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn x:Name="DustColumn" Header="가루" Binding="{Binding DustText}" Width="1.0*" ElementStyle="{StaticResource CellTextRightStyle}"/>
                        <DataGridTextColumn x:Name="CrystalColumn" Header="결정" Binding="{Binding CrystalText}" Width="0.8*" ElementStyle="{StaticResource CellTextRightStyle}"/>
                        <DataGridTextColumn x:Name="SeedColumn" Header="SEED" Binding="{Binding SeedText}" Width="1.3*" ElementStyle="{StaticResource CellTextRightStyle}"/>
                        <DataGridTextColumn x:Name="TicketColumn" Header="진화권" Binding="{Binding TicketCountText}" Width="0.9*" ElementStyle="{StaticResource CellTextRightStyle}"/>
                        <DataGridTextColumn x:Name="TotalCostColumn" Header="총 기대비용" Binding="{Binding TotalCostText}" Width="1.5*" ElementStyle="{StaticResource CellTextRightStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="SummaryTextBlock"
                           Grid.Row="2"
                           Foreground="#58A6FF"
                           FontSize="14"
                           Margin="2,0,2,2"
                           LineHeight="22"
                           TextWrapping="WrapWithOverflow"
                           Text="계산 대기"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
