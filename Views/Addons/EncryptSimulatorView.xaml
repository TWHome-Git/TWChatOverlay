<UserControl x:Class="TWChatOverlay.Views.Addons.EncryptSimulatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="#161B22" Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#161B22" Padding="16,12,12,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="0,0,0,6">
                    <TextBlock Text="인크립트 종류" Foreground="#8B949E" FontSize="14" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="VianuRadio" Content="비아누 인크립트" IsChecked="True" Foreground="#C9D1D9" FontSize="13" Margin="0,0,20,0" Checked="InkType_Checked"/>
                        <RadioButton x:Name="EtaRadio" Content="에타 인크립트" Foreground="#C9D1D9" FontSize="13" Checked="InkType_Checked"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="2" Height="1" Background="#30363D" CornerRadius="2" Margin="0,0,0,6"/>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="비용 프리셋" Foreground="#8B949E" FontSize="13" Margin="0,0,0,6"/>
                    <UniformGrid x:Name="CostPresetGrid" Columns="3" Margin="0,0,0,10">
                        <Button x:Name="EclipsePresetButton" Content="이클립스" Tag="2046" Click="CostPreset_Click" Style="{StaticResource PresetButtonStyle}"/>
                        <Button x:Name="SacredPresetButton" Content="세크리드" Tag="2946" Click="CostPreset_Click" Style="{StaticResource PresetButtonStyle}"/>
                        <Button x:Name="EffectPresetButton" Content="효과" Tag="666" Click="CostPreset_Click" Style="{StaticResource PresetButtonStyle}"/>
                    </UniformGrid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="BaseCostUnitTextBlock" Grid.Row="0" Grid.Column="0" Text="1회 비용 (만원)" Foreground="#8B949E" FontSize="13" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="현재 인크립트" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>

                        <TextBox x:Name="BaseCostTextBox" Grid.Row="1" Grid.Column="0" Text="2046" Height="34" Margin="0,0,8,0" Style="{StaticResource SimTextBoxStyle}"/>
                        <TextBox x:Name="StartInkTextBox" Grid.Row="1" Grid.Column="1" Text="0" Height="34" Style="{StaticResource SimTextBoxStyle}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                        <CheckBox x:Name="DiscountCheckBox"
                                  Content="비용 20% 할인 적용"
                                  Foreground="#C9D1D9"
                                  FontSize="13"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                  Checked="DiscountCheckBox_Changed"
                                  Unchecked="DiscountCheckBox_Changed"/>
                        <CheckBox x:Name="ElsoCheckBox"
                                  Content="엘소 전환"
                                  Foreground="#C9D1D9"
                                  FontSize="13"
                                  Margin="12,0,0,0"
                                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                  Checked="ElsoCheckBox_Changed"
                                  Unchecked="ElsoCheckBox_Changed"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ChanceInfoText" Foreground="#58A6FF" FontSize="13" Width="200"/>
                        <TextBlock x:Name="CostInfoText" Foreground="#58A6FF" FontSize="13" Width="200" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="4" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Background="#111821" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="수동 인크립트" Foreground="#C9D1D9" FontSize="16" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="횟수" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="ManualRunCountTextBox" Text="1" Width="110" Height="36" Style="{StaticResource SimTextBoxStyle}"/>
                            </StackPanel>
                            <Button Content="실행"
                                    Click="RunBatch_Click"
                                    Height="36"
                                    HorizontalAlignment="Stretch"
                                    Background="#21262D"
                                    Foreground="#C9D1D9"
                                    BorderBrush="#30363D"
                                    FontSize="14"
                                    Style="{StaticResource SimButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="2" Background="#111821" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="자동 인크립트" Foreground="#C9D1D9" FontSize="16" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="목표" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TargetInkTextBox" Text="5" Width="110" Height="36" Style="{StaticResource SimTextBoxStyle}"/>
                            </StackPanel>
                            <Button x:Name="AutoRunButton"
                                    Content="실행"
                                    Click="AutoRunButton_Click"
                                    Height="36"
                                    HorizontalAlignment="Stretch"
                                    Background="#4B3A74"
                                    Foreground="White"
                                    BorderBrush="#6E40C9"
                                    FontSize="14"
                                    Style="{StaticResource SimButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                            Content="초기화"
                            Click="Reset_Click"
                            Height="36"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Stretch"
                            Background="#21262D"
                            Foreground="#C9D1D9"
                            BorderBrush="#30363D"
                            FontSize="14"
                            Style="{StaticResource SimButtonStyle}"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="10,8,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="현재 인크" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="CurrentInkText" Foreground="White" FontWeight="SemiBold" Text="+0"/>
                        <TextBlock x:Name="CurrentChanceText" Foreground="#58A6FF" FontWeight="Normal" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="총 성공 / 시도" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="AttemptsAndSuccessText" Foreground="White" FontWeight="SemiBold" Text="0 / 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="총 비용" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="DestroyAndCostText" Foreground="White" FontWeight="SemiBold" Text="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="LuckInfoText" Foreground="#58A6FF" FontSize="13" Text="행운 지표: 계산 대기"/>
                    <TextBlock x:Name="LuckGraphText" Foreground="#C9D1D9" FontSize="12" FontFamily="Consolas" Margin="0,4,0,0" Text="계산 대기"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" BorderBrush="#30363D" BorderThickness="1" Background="#161B22" Padding="12" CornerRadius="8">
                <RichTextBox x:Name="ResultLogRichTextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E8ECF2"
                             FontSize="14"
                             IsReadOnly="True"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Auto"
                             IsDocumentEnabled="False"
                             PreviewMouseWheel="ResultLogRichTextBox_PreviewMouseWheel"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
