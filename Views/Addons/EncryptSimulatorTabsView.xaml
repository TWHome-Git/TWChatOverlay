<UserControl x:Class="TWChatOverlay.Views.Addons.EncryptSimulatorTabsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SimulatorTabItemStyle"
               TargetType="TabItem"
               BasedOn="{StaticResource SettingsTabItemStyle}">
            <Setter Property="MinWidth" Value="190"/>
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#161B22" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="시뮬레이터"
                   Foreground="#58A6FF"
                   FontSize="40"
                   FontWeight="SemiBold"
                   Margin="4,0,0,8"/>

        <TabControl x:Name="SimulatorTabControl"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectedIndex="0"
                    SelectionChanged="SimulatorTabControl_SelectionChanged">
            <TabItem Header="인크립트 시뮬레이터" Tag="Encrypt" Style="{StaticResource SimulatorTabItemStyle}" Margin="0,0,0,0"/>
            <TabItem Header="코어 강화 기대값" Tag="Core" Style="{StaticResource SimulatorTabItemStyle}" Margin="0,0,0,0"/>
            <TabItem Header="신조 렐릭 기대값" Tag="Relic" Style="{StaticResource SimulatorTabItemStyle}" Margin="0,0,0,0"/>
        </TabControl>

        <Border Grid.Row="3"
                Background="#101720"
                BorderBrush="#2E3A4A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <ContentControl x:Name="SimulatorContentHost"/>
        </Border>
    </Grid>
</UserControl>
