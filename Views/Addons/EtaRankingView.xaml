<UserControl x:Class="TWChatOverlay.Views.Addons.EtaRankingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#161B22" CornerRadius="8" Margin="0,0,15,0" BorderBrush="#30363D" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="5">
                    <TextBlock Text="에타 순위" Foreground="#58A6FF" FontSize="11" FontWeight="Bold" Margin="10,10,10,15"/>
                    <Button Content="전체" Tag="전체" Click="EtaCategoryButton_Click" Style="{StaticResource CategoryButtonStyle}"/>
                    <Separator Background="#30363D" Margin="5,10"/>

                    <ItemsControl x:Name="EtaCategoryMenuControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Foreground="White" BorderThickness="0" Margin="0,2">
                                    <Expander.Header>
                                        <Border Background="Transparent"
                                                CornerRadius="4"
                                                Padding="10,8"
                                                HorizontalAlignment="Stretch"
                                                Tag="{Binding MajorName}"
                                                PreviewMouseLeftButtonDown="EtaMajorCategory_Header_Click">
                                            <TextBlock Text="{Binding MajorName}" FontSize="13" VerticalAlignment="Center"/>
                                        </Border>
                                    </Expander.Header>

                                    <ItemsControl ItemsSource="{Binding SubCategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding}"
                                                        Tag="{Binding}"
                                                        Click="EtaCategoryButton_Click"
                                                        Style="{StaticResource SubCategoryButtonStyle}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1" Margin="0,0,0,10" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Foreground="#8B949E" Margin="0,0,10,0" FontSize="14"/>
                    <TextBox x:Name="EtaSearchBox" Grid.Column="1" Height="34" Padding="0,0,0,0" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13" VerticalContentAlignment="Center" TextChanged="EtaSearchBox_TextChanged" CaretBrush="Cyan"/>
                    <TextBlock Grid.Column="1" Text="아이디/캐릭터로 검색..." Foreground="#484F58" IsHitTestVisible="False" VerticalAlignment="Center" FontSize="13" Visibility="{Binding Text.IsEmpty, ElementName=EtaSearchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock x:Name="EtaUpdatedDateText" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,8,0" Foreground="#8B949E" FontSize="12" Text="갱신일: -"/>
                    <Button x:Name="EtaRefreshButton" Grid.Column="3" Width="88" Height="32" Margin="0,0,0,0" Click="EtaRefreshButton_Click" Style="{StaticResource SecondaryButtonStyle}" FontSize="12" Content="갱신 가능"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1"
                      x:Name="EtaRankingGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      RowBackground="#161B22"
                      AlternatingRowBackground="#1C2128"
                      BorderThickness="0"
                      Foreground="White"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#30363D"
                      HeadersVisibility="Column"
                      RowHeight="40">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Resources>
                    <Style x:Key="EtaGridTextCellTextStyle" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0D1117"/>
                        <Setter Property="Foreground" Value="#8B949E"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="순위" Binding="{Binding Rank}" Width="80" ElementStyle="{StaticResource EtaGridTextCellTextStyle}"/>
                    <DataGridTemplateColumn Header="캐릭터" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Width="34" Height="34" HorizontalAlignment="Center" Margin="4,0">
                                    <Border CornerRadius="4" BorderBrush="#30363D" BorderThickness="1" Background="#0D1117" ClipToBounds="True">
                                        <Grid ClipToBounds="True">
                                            <Image Source="{Binding CharacterImagePath}"
                                                   Width="34"
                                                   Height="34"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="아이디" Binding="{Binding UserId}" Width="*" ElementStyle="{StaticResource EtaGridTextCellTextStyle}"/>
                    <DataGridTextColumn Header="에타레벨" Binding="{Binding Level}" Width="110" ElementStyle="{StaticResource EtaGridTextCellTextStyle}"/>
                    <DataGridTextColumn Header="정수" Binding="{Binding Essence}" Width="110" ElementStyle="{StaticResource EtaGridTextCellTextStyle}"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid x:Name="EtaRefreshLoadingOverlay"
                  Grid.RowSpan="2"
                  Background="#AA0D1117"
                  Visibility="Collapsed"
                  Panel.ZIndex="100">
                <Border Width="260"
                        Padding="16"
                        CornerRadius="8"
                        Background="#161B22"
                        BorderBrush="#30363D"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="에타 랭킹 갱신 중..."
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <ProgressBar IsIndeterminate="True"
                                     Height="8"
                                     Margin="0,0,0,10"/>
                        <TextBlock x:Name="EtaRefreshLoadingText"
                                   Text="원격 데이터를 확인하고 있습니다."
                                   Foreground="#8B949E"
                                   FontSize="12"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
