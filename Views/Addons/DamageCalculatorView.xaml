<UserControl x:Class="TWChatOverlay.Views.Addons.DamageCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="#161B22" Margin="0,8,0,0">
        <Grid.Resources>
            <Style x:Key="GroupBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="#111821"/>
                <Setter Property="BorderBrush" Value="#30363D"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="MinHeight" Value="340"/>
            </Style>
            <Style x:Key="GroupTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#58A6FF"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
            <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#8B949E"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="InlineComboStyle" TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
                <Setter Property="Height" Value="24"/>
                <Setter Property="Width" Value="124"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
            </Style>
            <Style x:Key="CompactInlineComboStyle" TargetType="ComboBox" BasedOn="{StaticResource InlineComboStyle}">
                <Setter Property="Height" Value="24"/>
                <Setter Property="MinHeight" Value="24"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="4,1"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#111821"/>
                <Setter Property="BorderBrush" Value="#30363D"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#58A6FF"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
            <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#8B949E"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="SectionNoteStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#C9D1D9"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,2,0,0"/>
            </Style>
            <Style x:Key="SectionActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SimButtonStyle}">
                <Setter Property="Width" Value="96"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
            <Style x:Key="SectionSmallButtonStyle" TargetType="Button" BasedOn="{StaticResource SimButtonStyle}">
                <Setter Property="Width" Value="96"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
            <Style x:Key="HighlightBarStyle" TargetType="Border">
                <Setter Property="Background" Value="#0D1625"/>
                <Setter Property="BorderBrush" Value="#2E3A4A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>
            <Style x:Key="InlineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SimTextBoxStyle}">
                <Setter Property="Height" Value="24"/>
                <Setter Property="Width" Value="120"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="4,1"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
            </Style>
            <Style x:Key="SkillInfoTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InlineTextBoxStyle}">
                <Setter Property="Width" Value="64"/>
            </Style>
            <Style x:Key="GroupOpenButtonStyle" TargetType="Button" BasedOn="{StaticResource SimButtonStyle}">
                <Setter Property="Width" Value="96"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
        </Grid.Resources>

        <Border Background="#111821"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <StackPanel x:Name="NoDataPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="계수 계산기의 데이터를 입력하세요."
                               Foreground="#C9D1D9"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                    <TextBlock Text="캐릭터를 선택하고 계수 계산을 진행하면 대미지 계산기에 자동 반영됩니다."
                               Foreground="#8B949E"
                               FontSize="13"
                               Margin="0,10,0,0"
                               TextAlignment="Center"/>
                </StackPanel>

                <Grid x:Name="DataPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#0D1625"
                            BorderBrush="#2E3A4A"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0"
                                       VerticalAlignment="Center"
                                       ItemHeight="30">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="캐릭터" Margin="0,0,6,0"/>
                                <TextBlock x:Name="CharacterNameText" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,18,0"/>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="계산타입" Margin="0,0,6,0"/>
                                <TextBlock x:Name="CalculatorTypeText" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel x:Name="AnaisVariantPanel"
                                            Orientation="Horizontal"
                                            Visibility="Collapsed"
                                            Margin="0,0,14,0">
                                    <ComboBox x:Name="AnaisVariantComboBox"
                                              Width="70"
                                              SelectedIndex="0"
                                              Style="{StaticResource CompactInlineComboStyle}"
                                              SelectionChanged="AnaisVariantComboBox_SelectionChanged">
                                        <ComboBoxItem Content="마법"/>
                                        <ComboBoxItem Content="파괴"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="최종 계수" Margin="0,0,6,0"/>
                                <TextBlock x:Name="TotalCoefficientText" Foreground="#58A6FF" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </WrapPanel>

                            <WrapPanel Grid.Row="1"
                                       Margin="0,8,0,0"
                                       VerticalAlignment="Center"
                                       ItemHeight="30">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="몬스터" Margin="0,0,8,0"/>
                                <ComboBox x:Name="MonsterSelectComboBox"
                                          Width="154"
                                          Style="{StaticResource CompactInlineComboStyle}"
                                          SelectionChanged="MonsterSelectComboBox_SelectionChanged"/>
                                <TextBlock x:Name="MonsterSummaryText"
                                           Margin="14,0,0,0"
                                           Style="{StaticResource FieldLabelStyle}"
                                           VerticalAlignment="Center"
                                           Text="대미지 -"/>
                            </WrapPanel>

                            <StackPanel Visibility="Collapsed">
                                <TextBlock x:Name="TotalPrimaryText"/>
                                <TextBlock x:Name="PrimaryEnchantText"/>
                                <TextBlock x:Name="SecondarySummaryText"/>
                                <TextBlock x:Name="StatCoefficientText"/>
                                <TextBlock x:Name="EquipmentCoefficientText"/>
                                <TextBlock x:Name="DexCorrectionText"/>
                                <TextBlock x:Name="FinalCoefficientBreakdownText"/>
                                <TextBlock x:Name="CategorySummaryText"/>
                                <TextBlock x:Name="IntermediateDamageText"/>
                                <TextBlock x:Name="MinimumDamageText"/>
                                <TextBlock x:Name="MaximumDamageText"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,10,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource OverlayScrollViewerStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.05*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="스킬 정보"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionLabelStyle}" Text="스킬 배율"/>
                                            <TextBox x:Name="SkillMultiplierTextBox"
                                                     Grid.Row="0"
                                                     Grid.Column="1"
                                                     Text="0"
                                                     Style="{StaticResource SkillInfoTextBoxStyle}"
                                                     PreviewTextInput="NumberTextBox_PreviewTextInput"
                                                     PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                                                     DataObject.Pasting="NumberTextBox_OnPaste"
                                                     LostFocus="NumberTextBox_LostFocus"
                                                     TextChanged="BasicOption_TextChanged"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SectionLabelStyle}" Text="크리배율" Margin="0,6,0,0"/>
                                            <TextBox x:Name="CriticalMultiplierTextBox"
                                                     Grid.Row="1"
                                                     Grid.Column="1"
                                                     Margin="0,6,0,0"
                                                     Text="0"
                                                     Style="{StaticResource SkillInfoTextBoxStyle}"
                                                     PreviewTextInput="NumberTextBox_PreviewTextInput"
                                                     PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                                                     DataObject.Pasting="NumberTextBox_OnPaste"
                                                     LostFocus="NumberTextBox_LostFocus"
                                                     TextChanged="BasicOption_TextChanged"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SectionLabelStyle}" Text="타수" Margin="0,6,0,0"/>
                                            <TextBox x:Name="HitCountTextBox"
                                                     Grid.Row="2"
                                                     Grid.Column="1"
                                                     Margin="0,6,0,0"
                                                     Text="1"
                                                     Style="{StaticResource SkillInfoTextBoxStyle}"
                                                     PreviewTextInput="NumberTextBox_PreviewTextInput"
                                                     PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                                                     DataObject.Pasting="NumberTextBox_OnPaste"
                                                     LostFocus="NumberTextBox_LostFocus"
                                                     TextChanged="BasicOption_TextChanged"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SectionLabelStyle}" Text="무기 추가 대미지" Margin="0,6,0,0"/>
                                            <TextBox x:Name="WeaponAdditionalDamageTextBox"
                                                     Grid.Row="3"
                                                     Grid.Column="1"
                                                     Margin="0,6,0,0"
                                                     Text="0"
                                                     Style="{StaticResource SkillInfoTextBoxStyle}"
                                                     TextChanged="BasicOption_TextChanged"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource SectionLabelStyle}" Text="에타 레벨" Margin="0,6,0,0"/>
                                            <TextBox x:Name="EtaLevelTextBox"
                                                     Grid.Row="4"
                                                     Grid.Column="1"
                                                     Margin="0,6,0,0"
                                                     Text="1"
                                                     Style="{StaticResource SkillInfoTextBoxStyle}"
                                                     PreviewTextInput="EtaLevelTextBox_PreviewTextInput"
                                                     PreviewKeyDown="EtaLevelTextBox_PreviewKeyDown"
                                                     DataObject.Pasting="EtaLevelTextBox_OnPaste"
                                                     LostFocus="EtaLevelTextBox_LostFocus"
                                                     TextChanged="EtaLevelTextBox_TextChanged"/>

                                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource SectionLabelStyle}" Text="속성 값" Margin="0,6,0,0"/>
                                            <TextBox x:Name="ElementValueTextBox"
                                                     Grid.Row="5"
                                                     Grid.Column="1"
                                                     Margin="0,6,0,0"
                                                     Text="210"
                                                     Style="{StaticResource SkillInfoTextBoxStyle}"
                                                     TextChanged="BasicOption_TextChanged"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource SectionLabelStyle}" Text="특수 피해 감소율" Margin="0,6,0,0"/>
                                            <TextBox x:Name="SpecialDamageReductionTextBox"
                                                     Grid.Row="6"
                                                     Grid.Column="1"
                                                     Margin="0,6,0,0"
                                                     Text="0"
                                                     Style="{StaticResource SkillInfoTextBoxStyle}"
                                                     PreviewTextInput="NumberTextBox_PreviewTextInput"
                                                     PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                                                     DataObject.Pasting="NumberTextBox_OnPaste"
                                                     LostFocus="NumberTextBox_LostFocus"
                                                     TextChanged="SpecialDamageReductionTextBox_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="공격 피해량(이자벨)"/>
                                        <TextBlock x:Name="Group1SummaryText"
                                                   Foreground="#FFDE59"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"
                                                   Text="0% / 50%"/>
                                        <StackPanel x:Name="Group1InlineHost"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="공격 피해량(일반)"/>
                                        <TextBlock x:Name="Group2SummaryText"
                                                   Foreground="#FFDE59"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"
                                                   Text="0% / 30%"/>
                                        <StackPanel x:Name="Group2InlineHost"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource SectionCardStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="공격 피해량(캐릭터)"/>
                                        <TextBlock x:Name="Group4SummaryText"
                                                   Foreground="#FFDE59"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"
                                                   Text="0% / 80%"/>
                                        <StackPanel x:Name="Group4InlineHost"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.0*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="기본 정보"/>

                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="White" Text="어빌 - 전설의 스킬 공격력" VerticalAlignment="Center"/>
                                            <CheckBox x:Name="HelmetAbilityToggle"
                                                      Grid.Row="0"
                                                      Grid.Column="1"
                                                      Content=""
                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                                      HorizontalAlignment="Right"
                                                      Checked="BasicOption_Changed"
                                                      Unchecked="BasicOption_Changed">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Foreground="White" Text="부가 - 물리/마법 피해 증폭" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="EnemyTakenDamageWeaponToggle"
                                                      Grid.Row="1"
                                                      Grid.Column="1"
                                                      Content=""
                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                                      Margin="0,6,0,0"
                                                      HorizontalAlignment="Right"
                                                      Checked="CategoryToggle_Changed"
                                                      Unchecked="CategoryToggle_Changed">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Foreground="White" Text="콤보 보너스" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="ComboBonusToggle"
                                                      Grid.Row="2"
                                                      Grid.Column="1"
                                                      Content=""
                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                                      Margin="0,6,0,0"
                                                      HorizontalAlignment="Right"
                                                      Checked="ComboBonusToggle_Changed"
                                                      Unchecked="ComboBonusToggle_Changed">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>
                                        </Grid>

                                        <TextBlock x:Name="Group5SummaryText"
                                                   Margin="0,10,0,4"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="계열 공격력 0%"/>
                                        <StackPanel x:Name="Group5InlineHost"/>

                                        <TextBlock x:Name="Group11SummaryText"
                                                   Margin="0,10,0,4"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="추가 대미지 0%"/>
                                        <StackPanel x:Name="Group11InlineHost"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="캐릭터 특성"/>
                                        <TextBlock x:Name="SelectedModifierText"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Margin="0,2,0,8"
                                                   Text=""/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="공격 피해량(스킬) " Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Group3DamageSummaryText" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Text="0%"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="적이 받는 피해 증가 " Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TraitEnemyTakenDamageValueText" Text="0%" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="능력치 감소 " Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TraitStatReductionValueText" Text="0%" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="캐릭터 고유 값 " Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Group11TraitValueText" Text="0" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="최종 대미지"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="White" Text="클럽 공격력 증가" VerticalAlignment="Center"/>
                                            <CheckBox x:Name="ClubFinalDamageToggle"
                                                      Grid.Row="0"
                                                      Grid.Column="1"
                                                      Content=""
                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                                      HorizontalAlignment="Right"
                                                      Checked="FinalDamageOption_Changed"
                                                      Unchecked="FinalDamageOption_Changed">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Foreground="White" Text="코어 세트 효과" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                            <TextBox x:Name="CoreSetTextBox"
                                                     Grid.Row="1"
                                                     Grid.Column="1"
                                                     Margin="0,8,0,0"
                                                     Text="0"
                                                     Width="50"
                                                     Style="{StaticResource InlineTextBoxStyle}"
                                                     HorizontalAlignment="Right"
                                                     PreviewTextInput="NumberTextBox_PreviewTextInput"
                                                     PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                                                     DataObject.Pasting="NumberTextBox_OnPaste"
                                                     LostFocus="NumberTextBox_LostFocus"
                                                     TextChanged="FinalDamageOption_Changed"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Foreground="White" Text="에타 - 최종 대미지" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                            <ComboBox x:Name="EtaLinkFinalDamageComboBox"
                                                      Grid.Row="2"
                                                      Grid.Column="1"
                                                      Margin="0,8,0,0"
                                                      Width="80"
                                                      Style="{StaticResource CompactInlineComboStyle}"
                                                      HorizontalAlignment="Right"
                                                      SelectedIndex="0"
                                                      SelectionChanged="EtaLinkFinalDamageComboBox_SelectionChanged"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Foreground="White" Text="공격력 증가" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                            <TextBox x:Name="SienaTextBox"
                                                     Grid.Row="3"
                                                     Grid.Column="1"
                                                     Width="50"
                                                     Margin="0,10,0,0"
                                                     Text="0"
                                                     Style="{StaticResource InlineTextBoxStyle}"
                                                     HorizontalAlignment="Right"
                                                     TextChanged="SienaTextBox_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource SectionCardStyle}" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="치명타 배율"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="White" Text="약점 간파" VerticalAlignment="Center"/>
                                            <CheckBox x:Name="WeakPointToggle"
                                                      Grid.Row="0"
                                                      Grid.Column="1"
                                                      Content=""
                                                      Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                                                      HorizontalAlignment="Right"
                                                      Checked="WeakPointToggle_Changed"
                                                      Unchecked="WeakPointToggle_Changed">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Foreground="White" Text="정의의 심판" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                            <ComboBox x:Name="JudgementComboBox"
                                                      Grid.Row="1"
                                                      Grid.Column="1"
                                                      Margin="0,8,0,0"
                                                      Style="{StaticResource CompactInlineComboStyle}"
                                                      HorizontalAlignment="Right"
                                                      SelectedIndex="0"
                                                      SelectionChanged="JudgementComboBox_SelectionChanged"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Foreground="White" Text="에타 - 치명타 배율" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                            <ComboBox x:Name="EtaLinkCriticalComboBox"
                                                      Grid.Row="2"
                                                      Grid.Column="1"
                                                      Margin="0,8,0,0"
                                                      Style="{StaticResource CompactInlineComboStyle}"
                                                      HorizontalAlignment="Right"
                                                      SelectedIndex="0"
                                                      SelectionChanged="EtaLinkCriticalComboBox_SelectionChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
