<Window x:Class="TWChatOverlay.Views.Addons.EquipmentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="?λ퉬 ?곸꽭"
        Height="640"
        MinWidth="340"
        MinHeight="480"
        SizeToContent="Width"
        Background="#0D1117"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <sys:Double x:Key="TitleFontSize">15</sys:Double>
        <sys:Double x:Key="MaterialNameFontSize">13</sys:Double>
        <sys:Double x:Key="PriceInputFontSize">13</sys:Double>
        <sys:Double x:Key="TotalFontSize">13</sys:Double>
        <sys:Double x:Key="SectionTitleFontSize">13</sys:Double>
        <sys:Double x:Key="NoteFontSize">13</sys:Double>
        <Style x:Key="MaterialPriceTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="AcceptsReturn" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                Cursor="SizeAll">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0">
                <Button Content="-" Click="MinimizeButton_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                <Button Content="X" Click="CloseButton_Click" Style="{StaticResource WindowCloseButtonStyle}" Margin="0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopSectionRow" Height="Auto"/>
            <RowDefinition x:Name="SectionGapRow" Height="12"/>
            <RowDefinition x:Name="NoteSectionRow" Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="CraftSectionBorder"
                Grid.Row="0"
                Background="#1F2A38"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Grid Width="28" Height="28" Margin="0,0,8,0">
                        <Border Background="#050505"
                                BorderBrush="#AA2B2B"
                                BorderThickness="1"
                                CornerRadius="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Line X1="5" Y1="5" X2="23" Y2="23" Stroke="#FF3B3B" StrokeThickness="2"/>
                                <Line X1="23" Y1="5" X2="5" Y2="23" Stroke="#FF3B3B" StrokeThickness="2"/>
                            </Grid>
                        </Border>
                        <Image Source="{Binding ImagePath, TargetNullValue={x:Null}}" Width="28" Height="28">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="{StaticResource TitleFontSize}" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Row="2" BorderBrush="#30363D" BorderThickness="0,1,0,1" Padding="0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="재료 가격 입력 단위: 억"
                                   Foreground="#8B949E"
                                   FontSize="11"
                                   HorizontalAlignment="Right"/>
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="260">
                            <ItemsControl x:Name="MaterialsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="124"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Grid Width="20" Height="20" Margin="0,0,6,0">
                                                    <Border Background="#050505"
                                                            BorderBrush="#AA2B2B"
                                                            BorderThickness="1"
                                                            CornerRadius="2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Material.ImagePath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Line X1="4" Y1="4" X2="16" Y2="16" Stroke="#FF3B3B" StrokeThickness="1.7"/>
                                                            <Line X1="16" Y1="4" X2="4" Y2="16" Stroke="#FF3B3B" StrokeThickness="1.7"/>
                                                        </Grid>
                                                    </Border>
                                                    <Image Source="{Binding Material.ImagePath, TargetNullValue={x:Null}}" Width="20" Height="20">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Material.ImagePath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Grid>
                                                <TextBlock Foreground="White"
                                                           FontSize="{StaticResource MaterialNameFontSize}"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding DisplayName, Mode=OneWay}"/>
                                            </StackPanel>

                                            <TextBox Grid.Column="1"
                                                     Height="38"
                                                     Margin="10,0,0,0"
                                                     Style="{StaticResource MaterialPriceTextBoxStyle}"
                                                     FontSize="{StaticResource PriceInputFontSize}"
                                                     Background="#0D1117"
                                                     Foreground="White"
                                                     BorderBrush="#30363D"
                                                     BorderThickness="1"
                                                     CaretBrush="White"
                                                     Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}"
                                                     TextChanged="MaterialPriceTextBox_TextChanged"
                                                     LostFocus="MaterialPriceTextBox_LostFocus"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4" x:Name="TotalCostTextBlock" Foreground="White" FontSize="{StaticResource TotalFontSize}" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border x:Name="NoteSectionBorder"
                Grid.Row="2"
                Background="#1F2A38"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="비고" Foreground="#58A6FF" FontSize="{StaticResource SectionTitleFontSize}" FontWeight="Bold"/>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="NoteTextBlock" Foreground="#C9D1D9" FontSize="{StaticResource NoteFontSize}" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
    </Grid>
</Window>



