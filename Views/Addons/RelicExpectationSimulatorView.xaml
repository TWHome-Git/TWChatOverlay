<UserControl x:Class="TWChatOverlay.Views.Addons.RelicExpectationSimulatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="#161B22" Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#161B22" Padding="16,12,12,12">
            <StackPanel>
                <TextBlock Text="신조 렐릭 기대값" Foreground="#58A6FF" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <TextBlock Text="장비 종류" Foreground="#8B949E" FontSize="14" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <RadioButton x:Name="PendantRadio" Content="펜던트" IsChecked="True" Foreground="#C9D1D9" FontSize="13" Margin="0,0,18,0"/>
                    <RadioButton x:Name="BraceletRadio" Content="브레이슬릿" Foreground="#C9D1D9" FontSize="13"/>
                </StackPanel>

                <Border Height="1" Background="#30363D" CornerRadius="2" Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="현재 레벨 (0~19)" Grid.Row="0" Grid.Column="0" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>
                    <TextBlock Text="목표 레벨 (1~20)" Grid.Row="0" Grid.Column="2" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="CurrentLevelTextBox" Grid.Row="1" Grid.Column="0" Text="0" Height="34" Style="{StaticResource SimTextBoxStyle}"/>
                    <TextBox x:Name="TargetLevelTextBox" Grid.Row="1" Grid.Column="2" Text="10" Height="34" Style="{StaticResource SimTextBoxStyle}"/>
                </Grid>

                <TextBlock Text="강화 가능 단수 (1~20)" Foreground="#8B949E" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="DifficultyTextBox" Text="20" Height="34" Margin="0,0,0,14" Style="{StaticResource SimTextBoxStyle}"/>

                <Button Content="기대값 계산"
                        Click="CalculateButton_Click"
                        Height="38"
                        HorizontalAlignment="Stretch"
                        FontSize="14"
                        Style="{StaticResource SimButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="10,8,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#30363D" BorderThickness="1" Background="#161B22" Padding="8" CornerRadius="8" Margin="0,0,0,10">
                <DataGrid x:Name="ResultDataGrid"
                          AutoGenerateColumns="False"
                          Background="#0D1625"
                          BorderBrush="#2E3A4A"
                          BorderThickness="1"
                          Foreground="#E6EDF3"
                          FontSize="13"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          IsReadOnly="True"
                          RowHeight="30"
                          RowHeaderWidth="0"
                          SnapsToDevicePixels="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          GridLinesVisibility="Horizontal"
                          RowBackground="#0D1625"
                          AlternatingRowBackground="#121D2D"
                          HorizontalGridLinesBrush="#2E3A4A"
                          VerticalGridLinesBrush="#2E3A4A"
                          ColumnHeaderHeight="28">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1A2332"/>
                            <Setter Property="Foreground" Value="#F0F6FC"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#2E3A4A"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8,2"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#243247"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                        <Style x:Key="CellTextCenterStyle" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="단계" Binding="{Binding StageLabel}" Width="0.9*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn Header="확률" Binding="{Binding ChanceText}" Width="0.8*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn Header="시도" Binding="{Binding ExpectedAttemptsText}" Width="0.8*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn Header="신조의 가루" Binding="{Binding PowderText}" Width="1.0*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn Header="신조의 정수" Binding="{Binding EssenceText}" Width="1.0*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn Header="달의 파편" Binding="{Binding MoonPieceText}" Width="0.9*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                        <DataGridTextColumn Header="월광석" Binding="{Binding MoonStoneText}" Width="0.8*" ElementStyle="{StaticResource CellTextCenterStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="12">
                <TextBlock x:Name="SummaryTextBlock"
                           Foreground="#D6E8FF"
                           FontSize="14"
                           LineHeight="22"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
