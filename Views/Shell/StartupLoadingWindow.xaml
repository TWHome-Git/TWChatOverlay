<Window x:Class="TWChatOverlay.Views.StartupLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        Width="360"
        Height="160"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="18" Background="#F2242A36" BorderBrush="#556B7A" BorderThickness="1" Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Text="초기화중..."
                       Foreground="White"
                       FontSize="19"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <ProgressBar Grid.Row="2"
                         x:Name="ProgressBar"
                         Height="14"
                         Minimum="0"
                         Maximum="100"
                         Value="0"/>

            <TextBlock Grid.Row="4"
                       x:Name="StatusText"
                       Text="원본 로그를 준비하는 중입니다."
                       Foreground="#C8D2DD"
                       FontSize="12"
                       HorizontalAlignment="Center"/>

            <TextBlock Grid.Row="6"
                       x:Name="DateText"
                       Text=""
                       Foreground="#9FB0C2"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
