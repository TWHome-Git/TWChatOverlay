<Window x:Class="TWChatOverlay.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TWChatOverlay.Views"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        x:Name="RootWindow"
        ShowInTaskbar="False"
        Visibility="Visible"
        Title="TW Chat Overlay" Height="230" Width="538"
        MinHeight="100" MinWidth="538"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        Background="Transparent" 
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid Margin="0, 30, 0, 0">
        <!-- Experience Tracker -->
        <Border Background="#EE1A1A1B" 
                CornerRadius="5" 
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="0,-22,5,0"  
                Padding="10,4"
                Height="28"
                Panel.ZIndex="999"
                Visibility="{Binding ShowExpTracker, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel x:Name="ExpTrackerPanel" LastChildFill="True" VerticalAlignment="Center">
                <Button Click="ResetExp_Click" 
                        DockPanel.Dock="Right"
                        Foreground="#888" 
                        FontSize="14"
                        Margin="5,-8,0,0"
                        Width="16"
                        Height="16"
                        Cursor="Hand" 
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center" 
                                                Content="x">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="0,0,0,2"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalExpDisplay}" 
                               Foreground="#FFCC00" 
                               FontSize="13" 
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastGainedExpDisplay}" 
                               Foreground="#00FF00" 
                               FontSize="11" 
                               Margin="8,1,0,0"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasLastExp, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Border -->
        <Border x:Name="OuterEdge" Background="Transparent" Padding="5">
            <Border x:Name="MainBorder" TextElement.FontFamily="{Binding CurrentFont, RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#F51E1E1E" CornerRadius="10" 
                    BorderThickness="1.5" BorderBrush="#60FFFFFF" ClipToBounds="False">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="DragBarRow" Height="0"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Drag Bar (Window Move) -->
                    <Border Grid.Row="0"
                            x:Name="DragBar"
                            Background="#1A1A2E"
                            MouseLeftButtonDown="DragBar_MouseLeftButtonDown"
                            Visibility="Collapsed"
                            Cursor="Hand">
                        <TextBlock Text="⋮⋮ 드래그하여 창 이동 ⋮⋮"
                                   Foreground="#888"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontStyle="Italic"/>
                    </Border>

                    <!-- Tab Header -->
                    <Border Grid.Row="1" Background="#FF332255" CornerRadius="3,3,0,0"/>

                    <UniformGrid Grid.Row="1" Columns="8">
                        <RadioButton Content="기본" Style="{StaticResource TabButtonStyle}" IsChecked="True" Tag="Basic" Click="Tab_Click"/>
                        <RadioButton Content="일반" Style="{StaticResource TabButtonStyle}" Tag="General" Click="Tab_Click"/>
                        <RadioButton Content="팀" Style="{StaticResource TabButtonStyle}" Tag="Team" Click="Tab_Click"/>
                        <RadioButton Content="클럽" Style="{StaticResource TabButtonStyle}" Tag="Club" Click="Tab_Click"/>
                        <RadioButton Content="외치기" Style="{StaticResource TabButtonStyle}" Tag="Shout" Click="Tab_Click"/>
                        <RadioButton Content="시스템" Style="{StaticResource TabButtonStyle}" Tag="System" Click="Tab_Click"/>
                        <RadioButton Content="설정" Style="{StaticResource TabButtonStyle}" Tag="Settings" Click="Tab_Click"/>
                        <Button Content="+" Style="{StaticResource TabActionButtonStyle}" Click="AddChatWindow_Click"/>
                    </UniformGrid>

                    <!-- Chat View -->
                    <views:ChatView Grid.Row="2" x:Name="ChatDisplay"/>

                    <!-- Addon View (overlay) -->
                    <!--<views:AddonView Grid.Row="2" x:Name="AddonDisplay" Visibility="Collapsed"/>-->

                    <!-- Settings View (overlay) -->
                    <views:SettingsView Grid.Row="2" x:Name="SettingsDisplay" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Border>

        <!-- Resize Thumbs -->
        <primitives:Thumb Height="8" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="TopResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
        <primitives:Thumb Width="8" HorizontalAlignment="Left" Cursor="SizeWE" DragDelta="LeftResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
        <primitives:Thumb Width="8" HorizontalAlignment="Right" Cursor="SizeWE" DragDelta="RightResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>
