<Window x:Class="TWChatOverlay.Views.SubAddonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#E6161B22"
            BorderBrush="#30363D"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <StackPanel>
            <TextBlock x:Name="WindowTitleText"
                       Text="에토스 방향 안내"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="WindowHintText"
                       Text="드래그해서 위치를 옮길 수 있습니다"
                       Foreground="#9FB0C0"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <Border x:Name="HostContent"
                    Background="Transparent"/>
        </StackPanel>
    </Border>
</Window>
