<Window x:Class="TWChatOverlay.Views.SubMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sub Menu"
        Height="750"
        Width="1100"
        MinHeight="520"
        MinWidth="760"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Border Background="{DynamicResource PrimaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderTitle"
                       Grid.Row="0"
                       Text="Sub Menu"
                       Foreground="#7FDBFF"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="2,0,0,8"/>

            <Border x:Name="HostContent"
                    Grid.Row="1"
                    Background="#161B22"
                    BorderBrush="#30363D"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <TextBlock Text="표시할 화면이 없습니다."
                           Foreground="#9AA4B2"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
