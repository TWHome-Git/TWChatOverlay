<Window x:Class="TWChatOverlay.Views.SubMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="추가 기능"
        Height="750"
        Width="1100"
        MinHeight="520"
        MinWidth="760"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Border Background="{DynamicResource PrimaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#161B22"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Cursor="SizeAll">
                <Grid>
                    <TextBlock x:Name="HeaderTitle"
                               Text="추가 기능"
                               Foreground="#7FDBFF"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button HorizontalAlignment="Right"
                            Click="CloseButton_Click"
                            Content="X"
                            Style="{StaticResource WindowCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Border x:Name="HostContent"
                        Background="#161B22"
                        BorderBrush="#30363D"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <TextBlock Text="표시할 화면이 없습니다."
                               Foreground="#9AA4B2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
