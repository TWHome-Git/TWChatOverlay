<Window x:Class="TWChatOverlay.Views.BuffTrackerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        SizeToContent="Height"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Background="Transparent"
        AllowsTransparency="True" Height="87.66">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Border Background="#B01A1A1B"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8,6"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Visibility="{Binding HasRareBuffs, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="레어"
                           Foreground="#F8D66D"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding ActiveRareBuffs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,4" ToolTip="{Binding DisplayName}">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="8"
                                        Background="#18000000"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1">
                                    <Image Source="{Binding IconSource}"
                                           Stretch="Uniform"
                                           Margin="2"/>
                                </Border>
                                <TextBlock Text="{Binding RemainingText}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Visibility="{Binding HasExpBuffs, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="경험치"
                           Foreground="#9DDEF7"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding ActiveExpBuffs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,4" ToolTip="{Binding DisplayName}">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="8"
                                        Background="#18000000"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1">
                                    <Image Source="{Binding IconSource}"
                                           Stretch="Uniform"
                                           Margin="2"/>
                                </Border>
                                <TextBlock Text="{Binding RemainingText}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Border>
</Window>
