<Window x:Class="TWChatOverlay.Views.BuffTrackerHelperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        SizeToContent="Height"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#B01A1A1B"
            BorderBrush="#FF58A6FF"
            BorderThickness="1.2"
            CornerRadius="8"
            Padding="8,6"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0">
                <TextBlock Text="레어"
                           Foreground="#F8D66D"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Border Width="28"
                            Height="28"
                            CornerRadius="8"
                            Background="#22000000"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1">
                        <Rectangle Fill="#66F8D66D" Margin="4" RadiusX="3" RadiusY="3"/>
                    </Border>
                    <TextBlock Text="00:00"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="0">
                <TextBlock Text="경험치"
                           Foreground="#9DDEF7"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Border Width="28"
                            Height="28"
                            CornerRadius="8"
                            Background="#22000000"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1">
                        <Rectangle Fill="#669DDEF7" Margin="4" RadiusX="3" RadiusY="3"/>
                    </Border>
                    <TextBlock Text="00:00"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Grid.ColumnSpan="3"
                       Text="드래그해서 실제 버프 추적 위치를 맞추세요"
                       Foreground="#9FB0C0"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
        </Grid>
    </Border>
</Window>
