<Window x:Class="TWChatOverlay.Views.ChatCloneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TWChatOverlay.Views"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        x:Name="RootWindow"
        ShowInTaskbar="False"
        Visibility="Visible"
        Title="TW Chat Overlay"
        Height="230"
        Width="538"
        MinHeight="180"
        MinWidth="538"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Margin="0,30,0,0">
        <Border Background="Transparent" Padding="5">
            <Border x:Name="MainBorder"
                    TextElement.FontFamily="{Binding CurrentFont, RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#F51E1E1E"
                    CornerRadius="10"
                    BorderThickness="1.5"
                    BorderBrush="#60FFFFFF"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="DragBarRow" Height="0"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            x:Name="DragBar"
                            Background="#1A1A2E"
                            MouseLeftButtonDown="DragBar_MouseLeftButtonDown"
                            Visibility="Collapsed"
                            Cursor="Hand">
                        <TextBlock Text="⋮⋮ 설정에서 드래그하여 이동 ⋮⋮"
                                   Foreground="#888"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontStyle="Italic"/>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#FF332255"
                            CornerRadius="3,3,0,0"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <UniformGrid Grid.Column="0" Columns="6">
                            <RadioButton Content="일반" Style="{StaticResource TabButtonStyle}" IsChecked="True" Tag="General" Click="Tab_Click"/>
                            <RadioButton Content="팀" Style="{StaticResource TabButtonStyle}" Tag="Team" Click="Tab_Click"/>
                            <RadioButton Content="클럽" Style="{StaticResource TabButtonStyle}" Tag="Club" Click="Tab_Click"/>
                            <RadioButton Content="외치기" Style="{StaticResource TabButtonStyle}" Tag="Shout" Click="Tab_Click"/>
                            <RadioButton Content="시스템" Style="{StaticResource TabButtonStyle}" Tag="System" Click="Tab_Click"/>
                            <RadioButton Content="설정" Style="{StaticResource TabButtonStyle}" Tag="Settings" Click="Tab_Click"/>
                        </UniformGrid>

                        <Button Grid.Column="1"
                                Content="X"
                                Width="34"
                                Style="{StaticResource TabActionButtonStyle}"
                                ToolTip="채팅창 끄기"
                                Click="CloseChat_Click"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <views:ChatView x:Name="ChatDisplay"/>

                        <ScrollViewer x:Name="SettingsScrollViewer"
                                      Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="SettingsScrollViewer_PreviewMouseWheel"
                                      Background="Transparent">
                            <Border Background="#EE1A1A1B"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,8,0,0"
                                    Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="채팅창 설정"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="설정 탭에서는 창을 드래그해서 이동할 수 있습니다."
                                                   Foreground="#A8FFFFFF"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <CheckBox Grid.Row="1"
                                              Margin="0,14,0,0"
                                              Content="메인 채팅창 폰트 따라가기"
                                              IsChecked="{Binding FollowMainFont, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                              Style="{StaticResource ToggleSwitchCheckBoxStyle}"/>

                                    <Border Grid.Row="2"
                                            Margin="0,16,0,0"
                                            Background="Transparent">
                                        <StackPanel>
                                            <TextBlock Text="폰트"
                                                       Foreground="#DCE3EA"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding AvailableFonts}"
                                                      SelectedItem="{Binding SelectedFontFamily, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                      Style="{StaticResource DarkComboBoxStyle}"
                                                      IsEnabled="{Binding FollowMainFont, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanInverseConverter}}"
                                                      MinWidth="170"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="3"
                                            Margin="0,14,0,0"
                                            Background="Transparent">
                                        <StackPanel>
                                            <TextBlock Text="폰트 크기"
                                                       Foreground="#DCE3EA"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,8"/>
                                            <Slider Minimum="10"
                                                    Maximum="28"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding SelectedFontSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                    IsEnabled="{Binding FollowMainFont, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanInverseConverter}}"
                                                    SmallChange="1"
                                                    LargeChange="1"/>
                                            <TextBlock Text="{Binding SelectedFontSize, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=현재 크기: {0:0.#}pt}"
                                                       Foreground="#A8FFFFFF"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="4" Height="1" Background="Transparent"/>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <primitives:Thumb Height="8" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="TopResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
        <primitives:Thumb Width="8" HorizontalAlignment="Left" Cursor="SizeWE" DragDelta="LeftResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
        <primitives:Thumb Width="8" HorizontalAlignment="Right" Cursor="SizeWE" DragDelta="RightResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>
