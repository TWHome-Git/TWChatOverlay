<Window x:Class="TWChatOverlay.Views.ItemCalendarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="아이템 획득 내역"
        Width="1430"
        Height="880"
        MinWidth="1320"
        MinHeight="820"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="CalendarTitleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="34"/>
        </Style>
    </Window.Resources>

    <Border Background="#F21D1F23"
            BorderBrush="#60FFFFFF"
            BorderThickness="1"
            CornerRadius="12"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#FF2A2F38"
                    CornerRadius="10"
                    Padding="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="◀"
                                Width="34"
                                Margin="0,0,6,0"
                                Style="{StaticResource CalendarTitleButtonStyle}"
                                Click="PreviousMonth_Click"/>
                        <Button Content="이번달"
                                Width="76"
                                Margin="0,0,6,0"
                                Style="{StaticResource CalendarTitleButtonStyle}"
                                Click="ThisMonth_Click"/>
                        <Button Content="▶"
                                Width="34"
                                Style="{StaticResource CalendarTitleButtonStyle}"
                                Click="NextMonth_Click"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#9AA4B2"
                                   FontSize="12"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <Button Content="갱신"
                                Width="54"
                                Margin="0,0,6,0"
                                Style="{StaticResource CalendarTitleButtonStyle}"
                                Click="Refresh_Click"/>
                        <Button Content="닫기"
                                Width="54"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="Close_Click"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="아이템 획득 내역"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding MonthText}"
                                   Foreground="#C9D1D9"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#FF15181D"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,10,0">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding Days}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4"
                                            Padding="10"
                                            CornerRadius="10"
                                            BorderThickness="1"
                                            BorderBrush="#3D4650"
                                            Background="#FF20242B"
                                            Opacity="{Binding CellOpacity}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Background="Transparent"
                                                    BorderBrush="#3D4650"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="6,4">
                                                <TextBlock Text="{Binding DateLabel}"
                                                           Foreground="WhiteSmoke"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <ScrollViewer Grid.Row="1"
                                                          Margin="0,10,0,0"
                                                          VerticalScrollBarVisibility="Hidden"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          CanContentScroll="False"
                                                          VerticalAlignment="Stretch">
                                                <ItemsControl ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#2C323B"
                                                                    BorderBrush="{Binding BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="6,4"
                                                                    Margin="0,0,0,4">
                                                                <TextBlock Text="{Binding DisplayText}"
                                                                           Foreground="White"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#AA111317"
                                CornerRadius="8"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="280">
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>
                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Value="{Binding LoadProgressValue}"
                                             Height="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#FF15181D"
                        CornerRadius="10"
                        Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <StackPanel>
                            <TextBlock Text="어밴던 누적 합계"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <Border Background="#20242B"
                                    BorderBrush="#34404C"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="9"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="어밴던 누적 합계"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <Border Background="#232831"
                                            BorderBrush="#34404C"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8,6"
                                            Margin="0,0,0,8">
                                        <TextBlock Text="{Binding MonthlyAbaddonSeedText}"
                                                   Foreground="#A5D6FF"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding MonthlyAbaddonSummary}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2C323B"
                                                        BorderBrush="#46515B"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="7,5"
                                                        Margin="0,0,0,5">
                                                    <DockPanel LastChildFill="True">
                                                        <StackPanel Orientation="Horizontal"
                                                                    DockPanel.Dock="Left"
                                                                    VerticalAlignment="Center">
                                                            <Image Source="{Binding IconUri}"
                                                                   Width="14"
                                                                   Height="14"
                                                                   Margin="0,0,6,0"
                                                                   VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="White"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding CountText}"
                                                                   Foreground="#DCE3EA"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Right"
                                                                   DockPanel.Dock="Right"/>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="#20242B"
                                    BorderBrush="#34404C"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="9">
                                <StackPanel>
                                    <TextBlock Text="아이템 득템 누적 합계"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding MonthlySummary}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2C323B"
                                                        BorderBrush="{Binding BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="7,5"
                                                        Margin="0,0,0,5">
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="White"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   DockPanel.Dock="Left"/>
                                                        <TextBlock Text="{Binding Count, StringFormat=x{0:N0}}"
                                                                   Foreground="#DCE3EA"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Right"
                                                                   DockPanel.Dock="Right"/>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
