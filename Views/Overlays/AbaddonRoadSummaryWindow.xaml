<Window x:Class="TWChatOverlay.Views.AbandonRoadSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="어밴던로드 주간 합계"
        Width="420"
        Height="320"
        MinWidth="380"
        MinHeight="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="Window_Loaded">
    <Border Background="{DynamicResource OverlayWindowBackgroundBrush}"
            BorderBrush="{DynamicResource OverlayWindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource OverlaySurfaceAltBackgroundBrush}"
                    CornerRadius="10"
                    Padding="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="어밴던로드 주간 합계"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding WeekText}"
                                   Foreground="{DynamicResource OverlayInfoTextBrush}"
                                   FontSize="12"
                                   Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Click="Close_Click"
                            Content="X"
                            Style="{StaticResource WindowCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Background="{DynamicResource OverlayShellBackgroundBrush}"
                    CornerRadius="10"
                    Padding="10">
                <StackPanel>
                    <Border Background="{DynamicResource OverlayCardBackgroundBrush}"
                            BorderBrush="{DynamicResource OverlayCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,6"
                            Margin="0,0,0,10">
                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="{DynamicResource OverlayInfoTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding StoneEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource OverlayCardBackgroundBrush}"
                                        BorderBrush="{DynamicResource OverlayCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="7,6"
                                        Margin="0,0,0,5">
                                    <DockPanel LastChildFill="True">
                                        <StackPanel Orientation="Horizontal"
                                                    DockPanel.Dock="Left"
                                                    VerticalAlignment="Center">
                                            <Image Source="{Binding IconUri}"
                                                   Width="14"
                                                   Height="14"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{Binding NameForegroundHex}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding CountText}"
                                                   Foreground="{Binding CountForegroundHex}"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   DockPanel.Dock="Right"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
