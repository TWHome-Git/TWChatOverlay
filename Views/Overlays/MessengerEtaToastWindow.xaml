<Window x:Class="TWChatOverlay.Views.MessengerEtaToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320"
        Height="160"
        MinHeight="90"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Border Background="{DynamicResource OverlayWindowBackgroundBrush}"
            BorderBrush="{DynamicResource OverlayAccentBorderBrush}"
            BorderThickness="1.2"
            CornerRadius="8"
            Padding="12,8"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Background="{DynamicResource OverlayHighlightBackgroundBrush}"
                    CornerRadius="4"
                    Padding="6,4"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Text="1:1 채팅 에타레벨 확인"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>
                    <Button x:Name="CloseButton"
                            Content="X"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource WindowCloseButtonStyle}"/>
                </Grid>
            </Border>

            <RichTextBox Grid.Row="2"
                         Grid.ColumnSpan="2"
                         x:Name="EntryRichText"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         BorderThickness="0"
                         Background="{DynamicResource OverlayHighlightBackgroundBrush}"
                         Foreground="{DynamicResource OverlayInfoTextBrush}"
                         FontSize="20"
                         VerticalScrollBarVisibility="Disabled"/>
        </Grid>
    </Border>
</Window>
