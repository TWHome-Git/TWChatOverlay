<Window x:Class="TWChatOverlay.Views.ShoutToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="620"
        Height="72"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Border x:Name="RootBorder"
            Background="#F5211C21"
            BorderBrush="#E0FFB347"
            BorderThickness="1.2"
            CornerRadius="10"
            Padding="12,8"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Width="6"
                    CornerRadius="3"
                    Background="#FFB347"
                    VerticalAlignment="Stretch"
                    Margin="0,0,10,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="외치기"
                           Foreground="#FFD39A"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="ToastText"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
