<Window x:Class="TWChatOverlay.Views.DebugLogTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="디버그 로그 테스트"
        Width="980"
        Height="560"
        MinWidth="860"
        MinHeight="480"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="DebugCategoryRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource OverlayInfoTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource OverlayCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource OverlayStrongBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource OverlayTabSelectedBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource OverlayTabSelectedBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource OverlaySurfaceAltBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SampleLogTemplate">
            <Border x:Name="ItemBorder"
                    Background="{DynamicResource OverlayCardBackgroundBrush}"
                    BorderBrush="{DynamicResource OverlayStrongBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8"
                    Margin="0,0,0,6">
                <TextBlock Text="{Binding Text}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{Binding Foreground}"/>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource OverlayShellBackgroundBrush}"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource OverlayCardBorderBrush}"/>
                    <Setter TargetName="ItemBorder" Property="Margin" Value="0,4,0,8"/>
                    <Setter TargetName="ItemBorder" Property="Padding" Value="6"/>
                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0"/>
                    <Setter TargetName="ItemBorder" Property="IsHitTestVisible" Value="False"/>
                    <Setter TargetName="ItemBorder" Property="Cursor" Value="Arrow"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource OverlayWindowBackgroundBrush}"
            BorderBrush="{DynamicResource OverlayWindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.ColumnSpan="2"
                    Background="{DynamicResource OverlaySurfaceAltBackgroundBrush}"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="디버그 로그 테스트"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="선택한 분류로 실제 로그처럼 주입합니다."
                                   Foreground="{DynamicResource OverlayInfoTextBrush}"
                                   FontSize="12"
                                   Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Click="Close_Click"
                            Content="X"
                            Style="{StaticResource WindowCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    Background="{DynamicResource OverlayShellBackgroundBrush}"
                    CornerRadius="10"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="주입 패널"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="분류"
                               Foreground="{DynamicResource OverlaySubtleTextBrush}"
                               FontSize="12"
                               Margin="0,0,0,4"/>
                    <WrapPanel Margin="0,0,0,10">
                        <RadioButton x:Name="NormalRadio"
                                     Content="일반"
                                     Tag="Normal"
                                     GroupName="DebugCategory"
                                     Style="{StaticResource DebugCategoryRadioStyle}"
                                     Checked="DebugCategoryRadio_Checked"/>
                        <RadioButton x:Name="TeamRadio"
                                     Content="팀"
                                     Tag="Team"
                                     GroupName="DebugCategory"
                                     Style="{StaticResource DebugCategoryRadioStyle}"
                                     Checked="DebugCategoryRadio_Checked"/>
                        <RadioButton x:Name="ClubRadio"
                                     Content="클럽"
                                     Tag="Club"
                                     GroupName="DebugCategory"
                                     Style="{StaticResource DebugCategoryRadioStyle}"
                                     Checked="DebugCategoryRadio_Checked"/>
                        <RadioButton x:Name="SystemRadio"
                                     Content="시스템"
                                     Tag="System"
                                     GroupName="DebugCategory"
                                     Style="{StaticResource DebugCategoryRadioStyle}"
                                     Checked="DebugCategoryRadio_Checked"/>
                        <RadioButton x:Name="ShoutRadio"
                                     Content="외치기"
                                     Tag="Shout"
                                     GroupName="DebugCategory"
                                     Style="{StaticResource DebugCategoryRadioStyle}"
                                     Checked="DebugCategoryRadio_Checked"/>
                    </WrapPanel>

                    <TextBlock Text="주입할 로그"
                               Foreground="{DynamicResource OverlaySubtleTextBrush}"
                               FontSize="12"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="DebugLogInputTextBox"
                             Height="220"
                             Margin="0,0,0,8"
                             Background="{DynamicResource OverlaySurfaceBackgroundBrush}"
                             Foreground="White"
                             BorderBrush="{DynamicResource OverlayStrongBorderBrush}"
                             BorderThickness="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"/>

                    <Button Content="테스트 로그 주입"
                            Height="34"
                            Click="InjectDebugLogButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="12"/>

                    <Border Margin="0,12,0,0"
                            Background="{DynamicResource OverlayCardBackgroundBrush}"
                            BorderBrush="{DynamicResource OverlayCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="2줄 컨텐츠 테스트 프리셋"
                                       Foreground="{DynamicResource OverlayInfoTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="두 줄짜리 완료 로그를 순서대로 넣어 체크 흐름을 검증합니다."
                                       Foreground="{DynamicResource OverlaySubtleTextBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="코어 던전 완료"
                                        Height="34"
                                        Margin="0,0,6,0"
                                        Click="CoreDungeonTwoLineTestButton_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="12"/>
                                <Button Grid.Column="1"
                                        Content="오를리 완료"
                                        Height="34"
                                        Margin="6,0,0,0"
                                        Click="OrlyDefenseTwoLineTestButton_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource OverlayShellBackgroundBrush}"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,0,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="최근 주입 로그"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <ListBox x:Name="RecentLogsListBox"
                                 Background="{DynamicResource OverlayCardBackgroundBrush}"
                                 BorderBrush="{DynamicResource OverlayStrongBorderBrush}"
                                 Foreground="White"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MouseDoubleClick="RecentLogsListBox_MouseDoubleClick"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource OverlayShellBackgroundBrush}"
                        CornerRadius="10"
                        Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="샘플 문구"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <ListBox x:Name="SampleLogsListBox"
                                 Background="{DynamicResource OverlayCardBackgroundBrush}"
                                 BorderBrush="{DynamicResource OverlayStrongBorderBrush}"
                                 Foreground="White"
                                 ItemTemplate="{StaticResource SampleLogTemplate}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MouseDoubleClick="SampleLogsListBox_MouseDoubleClick"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
