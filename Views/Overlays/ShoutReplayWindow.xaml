<Window x:Class="TWChatOverlay.Views.ShoutReplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="외치기 로그"
        Height="640"
        Width="920"
        MinHeight="420"
        MinWidth="620"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Border Margin="10"
            Background="#10151D"
            BorderBrush="#2B3442"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#161B22"
                    BorderBrush="#30363D"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Padding="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Cursor="SizeAll">
                <Grid>
                    <TextBlock Text="외치기 로그"
                               Foreground="#7FDBFF"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            Click="CloseButton_Click"
                            Content="닫기"
                            Style="{StaticResource WindowCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <Button x:Name="BtnPrev" Content="&lt;" Width="34" Height="30" Margin="0,0,6,0" Click="Prev_Click"/>
                    <Button x:Name="BtnDate" Content="-" Width="180" Height="30" Click="Date_Click"/>
                    <Button x:Name="BtnNext" Content="&gt;" Width="34" Height="30" Margin="6,0,0,0" Click="Next_Click"/>
                    <Popup x:Name="DatePopup" PlacementTarget="{Binding ElementName=BtnDate}" Placement="Bottom" StaysOpen="False">
                        <Border Background="#1b1f26" BorderBrush="#3a4556" BorderThickness="1" Padding="8">
                            <DatePicker x:Name="DatePickerLog" SelectedDateChanged="DatePickerLog_SelectedDateChanged"/>
                        </Border>
                    </Popup>
                </DockPanel>

                <Grid Grid.Row="1" PreviewMouseDown="LogArea_PreviewMouseDown">
                    <Border Background="#10151D" BorderBrush="#2B3442" BorderThickness="1" CornerRadius="6">
                        <RichTextBox x:Name="LogRichText"
                                     IsReadOnly="True"
                                     IsDocumentEnabled="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="White"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="8"
                                     PreviewMouseWheel="LogRichText_PreviewMouseWheel"/>
                    </Border>
                    <Border x:Name="LoadingOverlay" Background="#88000000" Visibility="Collapsed" CornerRadius="6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="로딩 중.." Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" Width="180" Height="12" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
