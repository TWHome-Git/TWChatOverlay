<Window x:Class="TWChatOverlay.Views.DailyWeeklyContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TWChatOverlay.Models"
        Title="일간/주간 컨텐츠 확인"
        Width="280" Height="540"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                    <Setter Property="ResizeMode" Value="CanResize"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IncrementButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#FFCC00"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="Cyan"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CountButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Border Margin="0,30,0,0" Background="#E00D1117" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#161B22" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <DockPanel Margin="10,0,6,0" VerticalAlignment="Center">
                    <Button DockPanel.Dock="Right" Content="X" Click="Close_Click"
                            Width="22" Height="22" Cursor="Hand"
                            Style="{StaticResource CloseButtonStyle}"/>
                    <Button DockPanel.Dock="Right" Content="&#x2699;" Click="Settings_Click"
                            Width="22" Height="22" Cursor="Hand" Margin="0,0,2,0"
                            Style="{StaticResource SettingsButtonStyle}"/>
                    <TextBlock Text="일간/주간 컨텐츠 확인" Foreground="Cyan" FontSize="13"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,4">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource ChatScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <DockPanel Margin="0,2,4,6" LastChildFill="False">
                        <Border DockPanel.Dock="Left" Width="3" Background="Cyan" CornerRadius="1" Margin="0,0,6,0"/>
                        <TextBlock DockPanel.Dock="Left" Text="일일 컨텐츠" Foreground="#C9D1D9" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding DailyProgressDisplay}" Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding DailyContentItems}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DailyWeeklyContentLog}">
                            <Border Padding="4,2">
                                <DockPanel LastChildFill="True">
                                    <Border DockPanel.Dock="Left" Width="16"
                                            Visibility="{Binding IsSubItem, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock DockPanel.Dock="Left" Text="•" Foreground="#6E7681" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSubItem}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding VisualCountDisplay}"
                                               Foreground="#FFCC00" FontSize="11"
                                               VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowVisualCount}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#C9D1D9"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="FontSize" Value="13"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCleared}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <DockPanel Margin="0,8,4,6" LastChildFill="False">
                        <Border DockPanel.Dock="Left" Width="3" Background="Cyan" CornerRadius="1" Margin="0,0,6,0"/>
                        <TextBlock DockPanel.Dock="Left" Text="주간 컨텐츠" Foreground="#C9D1D9" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding WeeklyProgressDisplay}" Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding WeeklyContentItems}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DailyWeeklyContentLog}">
                                <Border Padding="4,2">
                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Left" Width="16"
                                                Visibility="{Binding IsSubItem, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock DockPanel.Dock="Left" Text="•" Foreground="#6E7681" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSubItem}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding VisualCountDisplay}"
                                                   Foreground="#FFCC00" FontSize="11"
                                                   VerticalAlignment="Center" Margin="4,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowVisualCount}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="13"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCleared}" Value="True">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 완료된 컨텐츠 -->
                    <DockPanel Margin="0,8,4,6" LastChildFill="False">
                        <DockPanel.Style>
                            <Style TargetType="DockPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCompletedItems}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DockPanel.Style>
                        <Border DockPanel.Dock="Left" Width="3" Background="#4CAF50" CornerRadius="1" Margin="0,0,6,0"/>
                        <TextBlock DockPanel.Dock="Left" Text="완료된 컨텐츠" Foreground="#4CAF50" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding CompletedItems}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCompletedItems}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DailyWeeklyContentLog}">
                                <Border Padding="4,2">
                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Left" Width="16"
                                                Visibility="{Binding IsSubItem, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock DockPanel.Dock="Left" Text="•" Foreground="#6E7681" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSubItem}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding VisualCountDisplay}"
                                                   Foreground="#FFCC00" FontSize="11"
                                                   VerticalAlignment="Center" Margin="4,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowVisualCount}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="13"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,4">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource ChatScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="항목 설정" Foreground="#8B949E" FontSize="11" Margin="4,4,0,6"/>
                    <ItemsControl ItemsSource="{Binding TrackItems}">
                        <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DailyWeeklyContentLog}">
                                <Border Padding="4,3">
                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Left" Width="16"
                                                Visibility="{Binding IsSubItem, Converter={StaticResource BoolToVis}}"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Button Content="-" Style="{StaticResource CountButtonStyle}"
                                                    Click="CountDown_Click" Tag="{Binding}"/>
                                            <TextBlock Text="{Binding EffectiveRequiredCount}"
                                                       Width="24" TextAlignment="Center"
                                                       Foreground="#FFCC00" VerticalAlignment="Center" FontSize="12"/>
                                            <Button Content="+" Style="{StaticResource CountButtonStyle}"
                                                    Click="CountUp_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Checked="SettingEnabled_Changed" Unchecked="SettingEnabled_Changed"
                                                  Tag="{Binding}">
                                            <CheckBox.Content>
                                                <TextBlock Text="{Binding Name}" Foreground="#C9D1D9" FontSize="12"/>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#161B22" CornerRadius="0,0,8,8" Padding="10,0">
                <DockPanel VerticalAlignment="Center">
                    <Button DockPanel.Dock="Right" Content="초기화" Click="Reset_Click"
                            Width="60" Height="24" Background="#21262D" Foreground="White"
                            BorderBrush="#30363D" BorderThickness="1" FontSize="11">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock Text="{Binding ProgressDisplay}"
                               Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- 설정 모드 리사이즈 핸들 -->
            <Border Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Width="20" Height="20" Cursor="SizeNWSE" Panel.ZIndex="10"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Background="Transparent">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Path Data="M 0,16 L 16,0 M 5,16 L 16,5 M 10,16 L 16,10"
                      Stroke="#8B949E" StrokeThickness="1.5" Opacity="0.8"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Border>

            <Border Grid.RowSpan="3" Background="#A010131A" Panel.ZIndex="100">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="28" Height="28" BorderBrush="#00BCD4" BorderThickness="3" CornerRadius="14" Margin="0,0,0,8"/>
                    <TextBlock Text="일일/주간 데이터를 불러오는 중..."
                               Foreground="#C9D1D9"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        </Border>

    </Grid>
</Window>
