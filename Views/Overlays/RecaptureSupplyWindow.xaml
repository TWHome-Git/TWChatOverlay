<Window x:Class="TWChatOverlay.Views.RecaptureSupplyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="보급품 탈환"
        Width="294"
        Height="204"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Border x:Name="RootBorder"
            Background="{DynamicResource OverlayWindowBackgroundBrush}"
            BorderBrush="{DynamicResource OverlayAccentBorderBrush}"
            BorderThickness="1.4"
            CornerRadius="12"
            Padding="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  MinHeight="28"
                  Margin="0,0,0,4"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="보급품 탈환"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="CloseButton_Click"
                        Content="X"
                        Style="{StaticResource WindowCloseButtonStyle}"/>
            </Grid>

            <Border Grid.Row="1"
                    Background="Transparent"
                    BorderBrush="{DynamicResource OverlayWindowBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="4">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Image x:Name="SupplyImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           SnapsToDevicePixels="True"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
