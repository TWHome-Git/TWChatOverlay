<Window x:Class="TWChatOverlay.Views.ItemDropHelperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        Height="56"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#A6191C22"
            BorderBrush="#FF58A6FF"
            BorderThickness="1.2"
            CornerRadius="8"
            Padding="12,6"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="아이템 드롭 알림 위치"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="드래그해서 실제 토스트 위치를 맞추세요"
                           Foreground="#9FB0C0"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
