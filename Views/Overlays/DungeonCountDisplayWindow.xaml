<Window x:Class="TWChatOverlay.Views.DungeonCountDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360"
        Height="76"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Opacity="0">
    <Border Background="#F0202229"
            BorderBrush="#FF58C7FF"
            BorderThickness="1.2"
            CornerRadius="8"
            Padding="16,10"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="던전 카운트"
                       Foreground="#FF58C7FF"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextAlignment="Center"/>

            <TextBlock x:Name="MessageTextBlock"
                       Grid.Row="1"
                       Margin="0,6,0,0"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>
    </Border>
</Window>
