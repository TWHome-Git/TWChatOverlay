<Window x:Class="TWChatOverlay.Views.ExperienceAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="122"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Border Background="#F0202229"
            BorderBrush="#FFF5A623"
            BorderThickness="1.4"
            CornerRadius="10"
            Padding="14,12"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Foreground="#FFF5C76B"
                       FontSize="15"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Grid.Row="0"
                    Grid.Column="1"
                    Width="26"
                    Height="26"
                    Margin="12,0,0,0"
                    Click="CloseButton_Click"
                    Background="#33FFFFFF"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    Foreground="White"
                    Cursor="Hand"
                    Content="X"/>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="2"
                       x:Name="MessageTextBlock"
                       Margin="0,14,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"/>
        </Grid>
    </Border>
</Window>
