<Window x:Class="TWChatOverlay.Views.ExperienceAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="122"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Border Background="#F0202229"
            BorderBrush="#FFF5A623"
            BorderThickness="1.4"
            CornerRadius="10"
            Padding="14,12"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="26"
                    Height="26"
                    Click="CloseButton_Click"
                    Background="#33FFFFFF"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    Foreground="White"
                    Cursor="Hand"
                    Content="X"/>

            <TextBlock x:Name="MessageTextBlock"
                       Margin="34,0,34,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"/>
        </Grid>
    </Border>
</Window>
