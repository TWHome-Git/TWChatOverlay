<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <CodePage>65001</CodePage>
    <ApplicationIcon>favicon.ico</ApplicationIcon>
    <Version>4.0.7</Version>
    <AssemblyVersion>$(Version).0</AssemblyVersion>
    <FileVersion>$(Version).0</FileVersion>
    <InformationalVersion>$(Version)</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove=".github\**" />
    <EmbeddedResource Remove=".github\**" />
    <None Remove=".github\**" />
    <Page Remove=".github\**" />
  </ItemGroup>

  <!-- Default None 항목에서 제외 (Resource로 재등록) -->
  <ItemGroup>
    <None Remove="Data\images\**\*" />
    <None Remove="Sound\*.wav" />
    <None Remove="sound\drop.mp3" />
    <None Remove="sound\drop_low.mp3" />
  </ItemGroup>

  <!-- 이미지/사운드 리소스 -->
  <ItemGroup>
    <Resource Include="Data\images\**\*" />
    <Resource Include="Sound\*.wav" />
    <Resource Include="sound\drop.mp3">
      <LogicalName>Sound/drop.mp3</LogicalName>
    </Resource>
    <Resource Include="sound\drop_low.mp3">
      <LogicalName>Sound/drop_low.mp3</LogicalName>
    </Resource>
  </ItemGroup>

  <ItemGroup>
    <Content Include="favicon.ico" />
  </ItemGroup>

</Project>
